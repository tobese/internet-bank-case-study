                    </Grid>

                    <!-- Observability row -->
                    <Border Background="#1A3040"
                            CornerRadius="8"
                            Padding="14,10"
                            Margin="0,16,0,0">
                        <TextBlock x:Uid="SystemDesign_ObservabilityRow"
                                   FontSize="13"
                                   Foreground="#99BBCC"
                                   HorizontalAlignment="Center"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"/>
                    </Border>

                    <!-- CI/CD row -->
                    <Border Background="#1A3020"
                            CornerRadius="8"
                            Padding="14,10"
                            Margin="0,8,0,0">
                        <TextBlock x:Uid="SystemDesign_CICDRow"
