<Page x:Class="InternetBankCalculator.SystemDesignPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{StaticResource BackgroundBrush}">

    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="740"
                    HorizontalAlignment="Center"
                    Padding="24,60,24,60"
                    Spacing="32">

            <!-- Header -->
            <StackPanel Spacing="12">
                <TextBlock x:Uid="SystemDesign_HeaderTitle"
                           Style="{StaticResource TitleTextBlockStyle}"/>
                <TextBlock x:Uid="SystemDesign_HeaderDescription"
                           FontSize="{StaticResource BodyFontSize}"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           TextWrapping="Wrap"/>
            </StackPanel>

            <!-- Architecture Overview (visual flow) -->
            <Border Background="#F5F7FA"
                    CornerRadius="12"
                    Padding="28"
                    BorderBrush="#D0D7E2"
                    BorderThickness="1">
                <StackPanel Spacing="0">
                    <TextBlock x:Uid="SystemDesign_ArchitectureOverviewTitle"
                               FontSize="{StaticResource SubtitleFontSize}"
                               FontWeight="SemiBold"
                               Foreground="White"
                               Margin="0,0,0,20"/>

                    <!-- Browser -->
                    <Border Background="#264060"
                            CornerRadius="8"
                            Padding="14,10">
                        <TextBlock x:Uid="SystemDesign_BrowserLabel"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"/>
                    </Border>

                    <StackPanel HorizontalAlignment="Center"
                                Spacing="0"
                                Margin="0,4,0,4">
                        <TextBlock x:Uid="SystemDesign_HTTPSLabel"
                                   FontSize="11"
                                   Foreground="#668899"
                                   HorizontalAlignment="Center"/>
                        <TextBlock x:Uid="SystemDesign_ArrowDown1"
                                   FontSize="14"
                                   Foreground="#668899"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>

                    <!-- AWS ALB -->
                    <Border Background="#264060"
                            CornerRadius="8"
                            Padding="14,10">
                        <TextBlock x:Uid="SystemDesign_AwsAlbLabel"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"/>
                    </Border>

                    <TextBlock x:Uid="SystemDesign_ArrowDown2"
                               FontSize="14"
                               Foreground="#668899"
                               HorizontalAlignment="Center"
                               Margin="0,4,0,4"/>

                    <!-- web-client pods -->
                    <Border Background="#264060"
                            CornerRadius="8"
                            Padding="14,10">
                        <StackPanel HorizontalAlignment="Center"
                                    Spacing="2">
                            <TextBlock x:Uid="SystemDesign_WebClientPodsLabel"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="White"
                                       HorizontalAlignment="Center"/>
                            <TextBlock x:Uid="SystemDesign_WebClientPodsDesc"
                                       FontSize="12"
                                       Foreground="#AAAACC"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <StackPanel HorizontalAlignment="Center"
                                Spacing="0"
                                Margin="0,4,0,4">
                        <TextBlock x:Uid="SystemDesign_ApiPathLabel"
                                   FontSize="11"
                                   Foreground="#668899"
                                   HorizontalAlignment="Center"/>
                        <TextBlock x:Uid="SystemDesign_ArrowDown3"
                                   FontSize="14"
                                   Foreground="#668899"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>

                    <!-- api pods -->
                    <Border Background="#264060"
                            CornerRadius="8"
                            Padding="14,10">
                        <StackPanel HorizontalAlignment="Center"
                                    Spacing="2">
                            <TextBlock x:Uid="SystemDesign_ApiPodsLabel"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="White"
                                       HorizontalAlignment="Center"/>
                            <TextBlock x:Uid="SystemDesign_ApiPodsDesc"
                                       FontSize="12"
                                       Foreground="#AAAACC"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Split arrows to DB / Cache -->
                    <Grid Margin="0,4,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="▼"
                                   FontSize="14"
                                   Foreground="#668899"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="1"
                                   Text="▼"
                                   FontSize="14"
                                   Foreground="#668899"
                                   HorizontalAlignment="Center"/>
                    </Grid>

                    <!-- PostgreSQL + Redis side by side -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0"
                                Background="#264060"
                                CornerRadius="8"
                                Padding="12,10">
                            <StackPanel HorizontalAlignment="Center"
                                        Spacing="2">
                                <TextBlock x:Uid="SystemDesign_PostgresLabel"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="White"
                                           HorizontalAlignment="Center"/>
                                <TextBlock x:Uid="SystemDesign_PostgresDesc"
                                           FontSize="11"
                                           Foreground="#AAAACC"
                                           HorizontalAlignment="Center"
                                           TextWrapping="Wrap"
                                           TextAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="2"
                                Background="#264060"
                                CornerRadius="8"
                                Padding="12,10">
