                               Foreground="#AAAACC"
                               LineHeight="22">
                        <Run>Browser  ──HTTPS──▶  AWS ALB (ACM TLS cert)</Run>
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap"
                               FontSize="13"
                               Foreground="#AAAACC"
                               LineHeight="22">
                        <Run>                         │</Run>
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap"
                               FontSize="13"
                               Foreground="#AAAACC"
                               LineHeight="22">
                        <Run>                         ▼</Run>
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap"
                               FontSize="13"
                               Foreground="#AAAACC"
                               LineHeight="22">
                        <Run>             web-client pods  (nginx + Uno WASM)</Run>
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap"
                               FontSize="13"
                               Foreground="#AAAACC"
                               LineHeight="22">
                        <Run>                    /api/*  │</Run>
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap"
                               FontSize="13"
                               Foreground="#AAAACC"
                               LineHeight="22">
                        <Run>                         ▼</Run>
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap"
                               FontSize="13"
                               Foreground="#AAAACC"
                               LineHeight="22">
                        <Run>               api pods  (Spring Boot · Java 21)</Run>
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap"
                               FontSize="13"
                               Foreground="#AAAACC"
                               LineHeight="22">
                        <Run>               ┌──────────────┴──────────────┐</Run>
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap"
                               FontSize="13"
                               Foreground="#AAAACC"
                               LineHeight="22">
                        <Run>               ▼                             ▼</Run>
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap"
                               FontSize="13"
                               Foreground="#AAAACC"
                               LineHeight="22">
                        <Run>         PostgreSQL 17                  Redis 7</Run>
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap"
                               FontSize="13"
                               Foreground="#AAAACC"
                               LineHeight="22">
                        <Run>         (StatefulSet)             (primes cache · 24 h TTL)</Run>
                    </TextBlock>
                    <TextBlock Text=" "
                               FontSize="6"/>
                    <TextBlock TextWrapping="Wrap"
                               FontSize="13"
                               Foreground="#668899"
                               LineHeight="22">
                        <Run>Observability:  Prometheus · Loki · Tempo  ──▶  Grafana</Run>
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap"
                               FontSize="13"
                               Foreground="#668899"
                               LineHeight="22">
                        <Run>CI/CD:  GitHub Actions  ──▶  ECR  ──▶  EKS rolling deploy</Run>
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- Request Flow -->
            <Border Background="White"
                    CornerRadius="12"
                    Padding="28"
                    BorderBrush="#E0E0E0"
                    BorderThickness="1">
                <Border.Shadow>
                    <ThemeShadow/>
                </Border.Shadow>
                <StackPanel Spacing="12">
                    <TextBlock Text="🌐  Request Flow"
                               FontSize="18"
                               FontWeight="SemiBold"/>
                    <TextBlock TextWrapping="Wrap"
                               Foreground="#333333"
                               FontSize="14"
                               LineHeight="22">
                        <Run>All traffic enters through an AWS Application Load Balancer. HTTP :80 is automatically redirected to HTTPS :443; TLS is terminated at the ALB using an ACM-managed certificate covering both doggerbank.online and www.doggerbank.online.</Run>
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap"
                               Foreground="#333333"
                               FontSize="14"
                               LineHeight="22">
                        <Run>The ALB forwards requests to the web-client service, which is backed by three or more nginx pods. Static assets (the Uno WASM bundle, fonts, images) are served directly from nginx. API calls — any path matching /api/* — are proxied upstream to the api Kubernetes service on port 8282.</Run>
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- Frontend -->
            <Border Background="White"
                    CornerRadius="12"
                    Padding="28"
                    BorderBrush="#E0E0E0"
                    BorderThickness="1">
                <Border.Shadow>
                    <ThemeShadow/>
                </Border.Shadow>
                <StackPanel Spacing="12">
                    <TextBlock Text="🖥️  Frontend — Uno Platform WebAssembly"
                               FontSize="18"
                               FontWeight="SemiBold"/>
                    <TextBlock TextWrapping="Wrap"
                               Foreground="#333333"
                               FontSize="14"
                               LineHeight="22">
                        <Run>The client is a C# / XAML application compiled to WebAssembly using Uno Platform (net10.0-browserwasm, Skia renderer). The entire application — runtime, fonts, assets — runs inside the browser's WASM sandbox with no server-side rendering.</Run>
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap"
                               Foreground="#333333"
                               FontSize="14"
                               LineHeight="22">
                        <Run>nginx serves the WASM bundle with gzip compression. index.html, AppManifest.js and service-worker.js carry no-store cache directives so the browser always fetches the latest version on reload, while the large WASM binary and asset files are cached aggressively by the service worker.</Run>
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap"
                               Foreground="#333333"
                               FontSize="14"
                               LineHeight="22">
                        <Run>The API base URL is resolved at runtime from window.location, so the same compiled binary works without modification behind any hostname — local Docker Compose or the cloud ALB.</Run>
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- API -->
            <Border Background="White"
                    CornerRadius="12"
                    Padding="28"
                    BorderBrush="#E0E0E0"
                    BorderThickness="1">
                <Border.Shadow>
                    <ThemeShadow/>
                </Border.Shadow>
                <StackPanel Spacing="12">
                    <TextBlock Text="☕  API — Spring Boot 3 · Java 21"
                               FontSize="18"
                               FontWeight="SemiBold"/>
                    <TextBlock TextWrapping="Wrap"
                               Foreground="#333333"
                               FontSize="14"
                               LineHeight="22">
                        <Run>The REST API is a Spring Boot 3.5.1 application running on Java 21 with virtual threads enabled for efficient async I/O. It exposes four operations under the /api prefix: factorial, fibonacci, streaming primes (Server-Sent Events), and mathematician of the day.</Run>
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap"
                               Foreground="#333333"
                               FontSize="14"
                               LineHeight="22">
                        <Run>Persistence uses Spring Data JPA with a HikariCP connection pool (max 10 connections). Primes results are cached in Redis with a 24-hour TTL — cache hits skip all computation and stream directly from the store, making the API stateless and safe to scale horizontally.</Run>
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap"
                               Foreground="#333333"
                               FontSize="14"
                               LineHeight="22">
                        <Run>Metrics are exposed on /actuator/prometheus via Micrometer with custom counters and timers for each math operation. Structured JSON logs are produced by logstash-logback-encoder. Distributed traces are emitted by the OpenTelemetry Java agent (zero-code instrumentation) to Tempo via OTLP/gRPC on port 4317.</Run>
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- Data Tier -->
            <Border Background="White"
                    CornerRadius="12"
                    Padding="28"
                    BorderBrush="#E0E0E0"
                    BorderThickness="1">
                <Border.Shadow>
                    <ThemeShadow/>
                </Border.Shadow>
                <StackPanel Spacing="12">
                    <TextBlock Text="🗄️  Data Tier — PostgreSQL &amp; Redis"
                               FontSize="18"
                               FontWeight="SemiBold"/>
                    <TextBlock TextWrapping="Wrap"
                               Foreground="#333333"
                               FontSize="14"
                               LineHeight="22">
                        <Run>PostgreSQL 17 runs as a Kubernetes StatefulSet with a persistent volume. The database is initialised on first start via an init SQL script that creates four tables: mathematicians (seeded with 10 entries), calculations, transactions, and audit_log. Indexes are created on all created_at columns and mathematicians.name.</Run>
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap"
                               Foreground="#333333"
                               FontSize="14"
                               LineHeight="22">
                        <Run>Redis 7 runs as a Deployment (ephemeral cache — no persistent volume). It stores primes results keyed by the upper limit with a 24-hour TTL. A postgres-exporter sidecar exposes PostgreSQL statistics (connections, transactions, replication lag) on port 9187 for Prometheus to scrape.</Run>
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- Observability -->
            <Border Background="White"
                    CornerRadius="12"
                    Padding="28"
                    BorderBrush="#E0E0E0"
                    BorderThickness="1">
                <Border.Shadow>
                    <ThemeShadow/>
                </Border.Shadow>
                <StackPanel Spacing="12">
                    <TextBlock Text="📊  Observability — Metrics · Logs · Traces"
                               FontSize="18"
                               FontWeight="SemiBold"/>
                    <TextBlock TextWrapping="Wrap"
                               Foreground="#333333"
                               FontSize="14"
                               LineHeight="22">
                        <Run>Three pillars of observability are covered by the same open-source stack used locally, now running inside the internet-bank Kubernetes namespace alongside the application.</Run>
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap"
                               Foreground="#333333"
                               FontSize="14"
                               LineHeight="22">
                        <Run>Metrics: Prometheus v3 scrapes the api and postgres-exporter every 15 seconds. Custom application metrics track request counts, computation latency, and Redis cache hit/miss ratios per operation. Grafana visualises these with pre-provisioned dashboards.</Run>
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap"
                               Foreground="#333333"
                               FontSize="14"
                               LineHeight="22">
                        <Run>Logs: Promtail runs as a DaemonSet, reading container logs from the Docker socket on each node and forwarding structured JSON to Loki. Log lines are queryable in Grafana using LogQL, correlated with traces via the trace ID injected into every log entry by the OTel agent.</Run>
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap"
                               Foreground="#333333"
                               FontSize="14"
                               LineHeight="22">
                        <Run>Traces: The OTel Java agent auto-instruments all HTTP requests, JDBC calls, and Redis operations. Spans are sent to Tempo over OTLP/gRPC. From Grafana you can jump from a slow request in a dashboard directly to its full distributed trace.</Run>
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- Infrastructure & Scaling -->
            <Border Background="White"
                    CornerRadius="12"
                    Padding="28"
                    BorderBrush="#E0E0E0"
                    BorderThickness="1">
                <Border.Shadow>
                    <ThemeShadow/>
                </Border.Shadow>
                <StackPanel Spacing="12">
                    <TextBlock Text="☁️  Infrastructure &amp; Auto-Scaling"
                               FontSize="18"
                               FontWeight="SemiBold"/>
                    <TextBlock TextWrapping="Wrap"
                               Foreground="#333333"
                               FontSize="14"
                               LineHeight="22">
                        <Run>The application runs in an Amazon EKS cluster in eu-central-1 (Frankfurt), inside a dedicated internet-bank namespace. Container images are stored in a private Amazon ECR repository.</Run>
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap"
                               Foreground="#333333"
                               FontSize="14"
                               LineHeight="22">
                        <Run>Both the api and web-client Deployments start with three replicas and are covered by a HorizontalPodAutoscaler (HPA). The api HPA scales between 3 and 10 pods, targeting 70% CPU; scale-up adds two pods per minute and scale-down removes one pod per minute with a 5-minute stabilisation window to avoid flapping. The web-client HPA uses the same CPU threshold plus an 80% memory target.</Run>
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap"
                               Foreground="#333333"
                               FontSize="14"
                               LineHeight="22">
                        <Run>PodDisruptionBudgets ensure at least two replicas of each service remain available during voluntary disruptions such as node drains or rolling updates. A NetworkPolicy restricts pod-to-pod traffic to only the paths required by the application.</Run>
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- CI/CD -->
            <Border Background="White"
                    CornerRadius="12"
                    Padding="28"
                    BorderBrush="#E0E0E0"
                    BorderThickness="1">
                <Border.Shadow>
                    <ThemeShadow/>
                </Border.Shadow>
                <StackPanel Spacing="12">
                    <TextBlock Text="🚀  CI/CD — GitHub Actions"
                               FontSize="18"
                               FontWeight="SemiBold"/>
                    <TextBlock TextWrapping="Wrap"
                               Foreground="#333333"
                               FontSize="14"
                               LineHeight="22">
                        <Run>Every push to the master branch triggers the CI/CD pipeline. The workflow builds the Uno WASM client with dotnet publish, runs the Spring Boot API build with Maven inside a multi-stage Docker build (compile → download OTel agent → JRE runtime image), and pushes both container images to ECR tagged as :latest.</Run>
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap"
                               Foreground="#333333"
                               FontSize="14"
                               LineHeight="22">
                        <Run>The pipeline then authenticates to the EKS cluster and issues a rolling update by patching the image on both Deployments. EKS performs the rollout gradually — new pods start, liveness and readiness probes pass, then old pods are terminated — keeping the application live throughout the deploy.</Run>
                    </TextBlock>
                    <Button x:Name="BtnGitHubActions"
                            Click="BtnGitHubActions_Click"
                            Background="#24292F"
                            Foreground="White"
                            CornerRadius="8"
                            Padding="18,10"
                            FontSize="14"
                            FontWeight="SemiBold"
                            HorizontalAlignment="Left">
                        <StackPanel Orientation="Horizontal"
                                    Spacing="8">
                            <TextBlock Text="⚙️"
                                       FontSize="16"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="View Pipeline Runs"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>

            <!-- Monitoring Tools -->
            <Border Background="White"
                    CornerRadius="12"
                    Padding="28"
                    BorderBrush="#E0E0E0"
                    BorderThickness="1">
                <Border.Shadow>
                    <ThemeShadow/>
                </Border.Shadow>
                <StackPanel Spacing="16">
                    <StackPanel Spacing="6">
                        <TextBlock Text="🔍  Monitoring Tools"
                                   FontSize="18"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="Available when running the local Docker Compose stack."
                                   FontSize="13"
                                   Foreground="#777777"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal"
                                Spacing="12">
                        <Button x:Name="BtnGrafana"
                                Click="BtnGrafana_Click"
                                Background="#F57C00"
                                Foreground="White"
                                CornerRadius="8"
                                Padding="18,10"
                                FontSize="14"
                                FontWeight="SemiBold">
                            <StackPanel Orientation="Horizontal"
                                        Spacing="8">
                                <TextBlock Text="📊"
                                           FontSize="16"
