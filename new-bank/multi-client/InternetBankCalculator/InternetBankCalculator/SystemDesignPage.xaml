                               Height="32"
                               Width="32"
                               Stretch="Uniform"
                               VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1"
                                    Spacing="2"
                                    Margin="14,0,0,0"
                                    VerticalAlignment="Center">
                            <TextBlock Text="Uno Platform"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="White"/>
                            <TextBlock Text="C# / XAML frontend compiled to WebAssembly"
                                       FontSize="12"
                                       Foreground="#8899BB"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Grid>
                    <Border Height="1"
                            Background="#2A2A4A"/>

                    <!-- Spring Boot -->
                    <Grid Padding="0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="32"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Image Grid.Column="0"
                               Source="ms-appx:///Assets/logo_springboot.png"
                               Height="32"
                               Width="32"
                               Stretch="Uniform"
                               VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1"
                                    Spacing="2"
                                    Margin="14,0,0,0"
                                    VerticalAlignment="Center">
                            <TextBlock Text="Spring Boot 3"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="White"/>
                            <TextBlock Text="Java 21 REST API — prime factorisation &amp; SSE streaming"
                                       FontSize="12"
                                       Foreground="#8899BB"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Grid>
                    <Border Height="1"
                            Background="#2A2A4A"/>

                    <!-- PostgreSQL -->
                    <Grid Padding="0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="32"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Image Grid.Column="0"
