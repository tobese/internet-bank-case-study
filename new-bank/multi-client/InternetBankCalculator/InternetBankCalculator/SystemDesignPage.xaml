                                        Spacing="2">
                                <TextBlock x:Uid="SystemDesign_RedisLabel"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           Foreground="White"
                                           HorizontalAlignment="Center"/>
                                <TextBlock x:Uid="SystemDesign_RedisDesc"
