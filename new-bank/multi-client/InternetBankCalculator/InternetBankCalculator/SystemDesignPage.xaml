<Page x:Class="InternetBankCalculator.SystemDesignPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F5F7FA">

    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="740"
                    HorizontalAlignment="Center"
                    Padding="24,60,24,60"
                    Spacing="32">

            <!-- Header -->
            <StackPanel Spacing="12">
                <TextBlock Text="⚙️ System Design"
                           FontSize="30"
                           FontWeight="Bold"
                           Foreground="#1A1A1A"/>
                <TextBlock Text="How doggerbank.online works — from a browser request to the database and back. A full-stack cloud-native application on AWS EKS."
                           FontSize="15"
                           Foreground="#555555"
                           TextWrapping="Wrap"/>
            </StackPanel>

            <!-- Architecture layers (dark code-style card) -->
