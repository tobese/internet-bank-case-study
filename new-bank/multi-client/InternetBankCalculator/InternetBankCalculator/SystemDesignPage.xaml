            <!-- API -->
            <Border Background="White"
                    CornerRadius="12"
                    Padding="28"
                    BorderBrush="#E0E0E0"
                    BorderThickness="1">
                <Border.Shadow>
                    <ThemeShadow/>
                </Border.Shadow>
                <StackPanel Spacing="12">
                    <TextBlock x:Uid="SystemDesign_ApiTitle"
                               FontSize="18"
                               FontWeight="SemiBold"/>
                    <TextBlock x:Uid="SystemDesign_ApiDesc1"
                               TextWrapping="Wrap"
                               Foreground="#333333"
                               FontSize="14"
                               LineHeight="22"/>
                    <TextBlock x:Uid="SystemDesign_ApiDesc2"
                               TextWrapping="Wrap"
                               Foreground="#333333"
                               FontSize="14"
                               LineHeight="22"/>
                    <TextBlock x:Uid="SystemDesign_ApiDesc3"
                               TextWrapping="Wrap"
                               Foreground="#333333"
                               FontSize="14"
                               LineHeight="22"/>
                </StackPanel>
            </Border>

            <!-- Data Tier -->
            <Border Background="White"
                    CornerRadius="12"
                    Padding="28"
                    BorderBrush="#E0E0E0"
                    BorderThickness="1">
