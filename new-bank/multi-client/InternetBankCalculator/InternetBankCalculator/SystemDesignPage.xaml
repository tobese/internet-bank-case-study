                               FontWeight="SemiBold"/>
                    <TextBlock x:Uid="SystemDesign_CICDDesc1"
                               TextWrapping="Wrap"
                               Foreground="#333333"
                               FontSize="14"
                               LineHeight="22"/>
                    <TextBlock x:Uid="SystemDesign_CICDDesc2"
                               TextWrapping="Wrap"
                               Foreground="#333333"
                               FontSize="14"
                               LineHeight="22"/>
                    <Button x:Name="BtnGitHubActions"
                            Click="BtnGitHubActions_Click"
