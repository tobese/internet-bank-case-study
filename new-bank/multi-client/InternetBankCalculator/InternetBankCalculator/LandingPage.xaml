<Page x:Class="InternetBankCalculator.LandingPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:InternetBankCalculator"
      Background="{StaticResource BackgroundBrush}">

    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="780"
                    HorizontalAlignment="Center"
                    Padding="24,60,24,60"
                    Spacing="40">

            <!-- Hero -->
            <StackPanel HorizontalAlignment="Center"
                        Spacing="16">
                <Image Source="ms-appx:///Assets/doggerbank.png"
                       MaxWidth="320"
                       Stretch="Uniform"
                       HorizontalAlignment="Center"/>
                <TextBlock x:Uid="Landing_WelcomeTitle"
                           Style="{StaticResource TitleTextBlockStyle}"
                           HorizontalAlignment="Center"/>
                <TextBlock x:Uid="Landing_WelcomeDescription"
                           FontSize="{StaticResource BodyFontSize}"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           TextWrapping="Wrap"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           MaxWidth="560"/>
            </StackPanel>

            <!-- Calculator card -->
            <Border MaxWidth="340"
                    HorizontalAlignment="Center"
                    Background="White"
                    CornerRadius="12"
                    Padding="32"
                    BorderBrush="{StaticResource AccentBrush}"
                    BorderThickness="1">
                <Border.Shadow>
                    <ThemeShadow/>
                </Border.Shadow>
                <StackPanel Spacing="12">
                    <Image Source="https://static.wikia.nocookie.net/computerscience/images/c/cf/Abacus.jpg/revision/latest?cb=20140901191838"
                           MaxWidth="48"
                           Stretch="Uniform"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,8"/>
                    <TextBlock x:Uid="Landing_CalcTitle"
                               FontSize="18"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"/>
                    <TextBlock x:Uid="Landing_CalcDescription"
                               FontSize="13"
                               Foreground="#444444"
                               TextWrapping="Wrap"
                               TextAlignment="Center"/>
                    <Button x:Name="BtnToCalc"
                            x:Uid="Landing_OpenCalculatorButton"
                            Click="BtnToCalc_Click"
                            HorizontalAlignment="Center"
                            Background="#1565C0"
                            Foreground="White"
                            FontWeight="SemiBold"
                            Padding="20,10"
                            CornerRadius="8"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
