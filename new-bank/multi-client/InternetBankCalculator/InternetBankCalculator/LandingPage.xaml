<Page x:Class="InternetBankCalculator.LandingPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:InternetBankCalculator"
      Background="#F5F7FA">

    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="780"
                    HorizontalAlignment="Center"
                    Padding="24,60,24,60"
                    Spacing="40">

            <!-- Hero -->
            <StackPanel HorizontalAlignment="Center"
                        Spacing="16">
                <Image Source="ms-appx:///Assets/doggerbank.png"
                       MaxWidth="320"
                       Stretch="Uniform"
                       HorizontalAlignment="Center"/>
                <TextBlock Text="Welcome to Doggerbank"
                           FontSize="32"
                           FontWeight="Bold"
                           Foreground="#1A1A1A"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="A floating point bank at the edge of the North Sea — calculator, history, and the deep story of the land beneath the waves."
                           FontSize="15"
                           Foreground="#555555"
                           TextWrapping="Wrap"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           MaxWidth="560"/>
            </StackPanel>

            <!-- Calculator card -->
            <Border MaxWidth="340"
                    HorizontalAlignment="Center"
                    Background="White"
                    CornerRadius="12"
                    Padding="32"
                    BorderBrush="#E0E0E0"
                    BorderThickness="1">
                <Border.Shadow>
                    <ThemeShadow/>
                </Border.Shadow>
                <StackPanel Spacing="12">
                    <Image Source="ms-appx:///Assets/abacus.png"
                           MaxWidth="48"
                           Stretch="Uniform"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,4"/>
                    <TextBlock Text="Calculator"
                               FontSize="18"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Arithmetic, factorial, Fibonacci and prime number streaming — all powered by the Java Math API."
                               FontSize="13"
                               Foreground="#444444"
                               TextWrapping="Wrap"
                               TextAlignment="Center"/>
                    <Button Content="Open Calculator"
                            x:Name="BtnToCalc"
                            Click="BtnToCalc_Click"
                            HorizontalAlignment="Center"
                            Background="#1565C0"
                            Foreground="White"
                            FontWeight="SemiBold"
                            Padding="20,10"
                            CornerRadius="8"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
