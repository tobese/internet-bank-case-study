<Page
    x:Class="InternetBankCalculator.Uprising.Slide4Page"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:InternetBankCalculator.Uprising">
    <Grid>
        <StackPanel HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="24">
            <TextBlock Text="Slide 4: The Turning Point"
                    FontSize="24"
                    FontWeight="Bold"/>
            <TextBlock Text="Momentum builds, change is near."
                    FontSize="16"/>
            <Button Content="Back"
                    Width="100"
                    Height="40"
                    Click="OnBackClick"/>
            <Button Content="Next"
                    Width="100"
                    Height="40"
                    Click="OnNextClick"/>
        </StackPanel>
    </Grid>
</Page>
