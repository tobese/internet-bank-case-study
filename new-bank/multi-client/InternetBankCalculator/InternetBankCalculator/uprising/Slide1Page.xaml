<Page
    x:Class="InternetBankCalculator.Uprising.Slide1Page"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:InternetBankCalculator.Uprising">
    <Grid>
        <StackPanel HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Spacing="24">
            <TextBlock Text="Slide 1: The Spark"
                    FontSize="24"
                    FontWeight="Bold"/>
            <TextBlock Text="Every uprising begins with a spark of change."
                    FontSize="16"/>
            <Button Content="Next"
                    Width="120"
                    Height="40"
                    Click="OnNextClick"/>
        </StackPanel>
    </Grid>
</Page>
