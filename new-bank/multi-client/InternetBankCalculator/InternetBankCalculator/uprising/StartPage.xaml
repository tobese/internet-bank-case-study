<Page
    x:Class="InternetBankCalculator.Uprising.StartPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:InternetBankCalculator.Uprising">
    <Grid>
        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="24">
            <TextBlock Text="Welcome to the Uprising Slideshow"
                       FontSize="28"
                       FontWeight="Bold"/>
            <TextBlock Text="Click Next to begin the journey."
                       FontSize="16"/>
            <Image Source="Assets/doggerland_map.png"
                    Height="180"
                    Margin="0,0,0,16"/>
            <Button Content="Next"
                    Width="120"
                    Height="40"
                    Click="OnNextClick"/>
        </StackPanel>
    </Grid>
</Page>
