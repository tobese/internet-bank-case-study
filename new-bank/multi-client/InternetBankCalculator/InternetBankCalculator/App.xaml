<Application
        x:Class="InternetBankCalculator.App"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:Converters="using:InternetBankCalculator.Converters">

        <Application.Resources>
                <ResourceDictionary>
                        <ResourceDictionary.MergedDictionaries>
                                <!--  Load Material theme (includes WinUI controls resources)  -->
                                <MaterialTheme xmlns="using:Uno.Material" />
                        </ResourceDictionary.MergedDictionaries>

                        <Style
                                x:Key="TitleTextBlockStyle"
                                BasedOn="{ThemeResource HeadlineSmall}"
                                TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#1A1A1A" />
                        </Style>
                        <Style
                                x:Key="SubtitleTextBlockStyle"
                                BasedOn="{ThemeResource TitleLarge}"
                                TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#333" />
                        </Style>

                        <!--  Add resources here  -->
                        <Converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
                        <SolidColorBrush x:Key="ResultBackgroundSuccess" Color="#F0F4F8" />
                        <SolidColorBrush x:Key="ResultBackgroundError" Color="#FDECEA" />
                        <SolidColorBrush x:Key="ResultForegroundSuccess" Color="#1A1A1A" />
                        <SolidColorBrush x:Key="ResultForegroundError" Color="#C62828" />

                        <SolidColorBrush x:Key="ButtonCalculateBackground" Color="#4A90D9" />
                        <SolidColorBrush x:Key="ButtonFacBackground" Color="#34A853" />
                        <SolidColorBrush x:Key="ButtonFibBackground" Color="#00838F" />
                        <SolidColorBrush x:Key="ButtonForeground" Color="White" />

                        <Converters:BoolToBrushConverter
                                x:Key="BoolToBackgroundConverter"
                                FalseBrush="{StaticResource ResultBackgroundSuccess}"
                                TrueBrush="{StaticResource ResultBackgroundError}" />
                        <Converters:BoolToBrushConverter
                                x:Key="BoolToForegroundConverter"
                                FalseBrush="{StaticResource ResultForegroundSuccess}"
                                TrueBrush="{StaticResource ResultForegroundError}" />

                        <!--  Default dark text for all TextBlocks so light-background pages are always readable  -->
                        <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#1A1A1A" />
                        </Style>

                        <Style x:Key="NavButtonStyle" TargetType="Button">
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="Foreground" Value="White" />
                                <Setter Property="BorderThickness" Value="0" />
                                <Setter Property="Padding" Value="12,8" />
                                <Setter Property="FontSize" Value="14" />
                                <Setter Property="CornerRadius" Value="6" />
                                <Setter Property="Template">
                                        <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                        <ContentPresenter
                                                                x:Name="ContentPresenter"
                                                                Padding="{TemplateBinding Padding}"
                                                                HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                                VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                                                Background="{TemplateBinding Background}"
                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                                Content="{TemplateBinding Content}"
                                                                CornerRadius="{TemplateBinding CornerRadius}"
                                                                Foreground="{TemplateBinding Foreground}">
                                                                <VisualStateManager.VisualStateGroups>
                                                                        <VisualStateGroup x:Name="CommonStates">
                                                                                <VisualState x:Name="Normal" />
                                                                                <VisualState x:Name="PointerOver">
                                                                                        <VisualState.Setters>
                                                                                                <Setter Target="ContentPresenter.Background" Value="#2E2E50" />
                                                                                                <Setter Target="ContentPresenter.Foreground" Value="White" />
                                                                                        </VisualState.Setters>
                                                                                </VisualState>
                                                                                <VisualState x:Name="Pressed">
                                                                                        <VisualState.Setters>
                                                                                                <Setter Target="ContentPresenter.Background" Value="#3D3D6B" />
                                                                                                <Setter Target="ContentPresenter.Foreground" Value="White" />
                                                                                        </VisualState.Setters>
                                                                                </VisualState>
                                                                                <VisualState x:Name="Disabled">
                                                                                        <VisualState.Setters>
                                                                                                <Setter Target="ContentPresenter.Foreground" Value="#666688" />
                                                                                        </VisualState.Setters>
                                                                                </VisualState>
                                                                        </VisualStateGroup>
                                                                </VisualStateManager.VisualStateGroups>
                                                        </ContentPresenter>
                                                </ControlTemplate>
                                        </Setter.Value>
                                </Setter>
                        </Style>

                </ResourceDictionary>
        </Application.Resources>

</Application>
