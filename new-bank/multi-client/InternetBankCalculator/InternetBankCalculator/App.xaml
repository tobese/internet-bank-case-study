<Application x:Class="InternetBankCalculator.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:Converters="using:InternetBankCalculator.Converters">

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Load WinUI resources -->
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Add resources here -->
            <Converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
            <SolidColorBrush x:Key="ResultBackgroundSuccess"
                             Color="#F0F4F8"/>
            <SolidColorBrush x:Key="ResultBackgroundError"
                             Color="#FDECEA"/>
            <SolidColorBrush x:Key="ResultForegroundSuccess"
                             Color="#1A1A1A"/>
            <SolidColorBrush x:Key="ResultForegroundError"
                             Color="#C62828"/>

            <SolidColorBrush x:Key="ButtonCalculateBackground"
                             Color="#4A90D9"/>
            <SolidColorBrush x:Key="ButtonFacBackground"
                             Color="#34A853"/>
            <SolidColorBrush x:Key="ButtonFibBackground"
                             Color="#00838F"/>
            <SolidColorBrush x:Key="ButtonForeground"
                             Color="White"/>

            <Converters:BoolToBrushConverter x:Key="BoolToBackgroundConverter"
                                             TrueBrush="{StaticResource ResultBackgroundError}"
                                             FalseBrush="{StaticResource ResultBackgroundSuccess}"/>
            <Converters:BoolToBrushConverter x:Key="BoolToForegroundConverter"
                                             TrueBrush="{StaticResource ResultForegroundError}"
                                             FalseBrush="{StaticResource ResultForegroundSuccess}"/>

            <!-- Default dark text for all TextBlocks so light-background pages are always readable -->
            <Style TargetType="TextBlock">
                <Setter Property="Foreground"
                        Value="#1A1A1A"/>
            </Style>

            <Style x:Key="NavButtonStyle"
                   TargetType="Button">
                <Setter Property="Background"
                        Value="Transparent"/>
                <Setter Property="Foreground"
                        Value="White"/>
                <Setter Property="BorderThickness"
                        Value="0"/>
                <Setter Property="Padding"
                        Value="12,8"/>
                <Setter Property="FontSize"
                        Value="14"/>
                <Setter Property="CornerRadius"
                        Value="6"/>
            </Style>

        </ResourceDictionary>
    </Application.Resources>

</Application>
