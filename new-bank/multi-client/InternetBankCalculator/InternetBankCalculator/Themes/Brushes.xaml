<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Brushes based on color resources for easy theme changes -->
    <SolidColorBrush x:Key="PrimaryBrush"
            Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="SecondaryBrush"
            Color="{StaticResource SecondaryColor}"/>
    <SolidColorBrush x:Key="AccentBrush"
            Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="ErrorBrush"
            Color="{StaticResource ErrorColor}"/>
    <SolidColorBrush x:Key="SuccessBrush"
            Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="BackgroundBrush"
            Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="ErrorBackgroundBrush"
            Color="{StaticResource ErrorBackgroundColor}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush"
            Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush"
            Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="DisabledTextBrush"
            Color="{StaticResource DisabledTextColor}"/>
    <SolidColorBrush x:Key="NavButtonPointerOverBrush"
            Color="{StaticResource NavButtonPointerOver}"/>
    <SolidColorBrush x:Key="NavButtonPressedBrush"
            Color="{StaticResource NavButtonPressed}"/>
</ResourceDictionary>
