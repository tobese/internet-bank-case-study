<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- App-wide color resources for easy tweaking -->
    <Color x:Key="PrimaryColor">#4A90D9</Color>
    <Color x:Key="SecondaryColor">#34A853</Color>
    <Color x:Key="AccentColor">#00838F</Color>
    <Color x:Key="ErrorColor">#C62828</Color>
    <Color x:Key="SuccessColor">#1A1A1A</Color>
    <Color x:Key="BackgroundColor">#F0F4F8</Color>
    <Color x:Key="ErrorBackgroundColor">#FDECEA</Color>
    <Color x:Key="TextPrimaryColor">#1A1A1A</Color>
    <Color x:Key="TextSecondaryColor">#333333</Color>
    <Color x:Key="DisabledTextColor">#666688</Color>
    <Color x:Key="NavButtonPointerOver">#2E2E50</Color>
    <Color x:Key="NavButtonPressed">#3D3D6B</Color>
</ResourceDictionary>
