<Page
    x:Class="InternetBankCalculator.CloudBankingPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer>
        <StackPanel Spacing="24"
                Margin="24">
            <TextBlock Text="Cloud Banking: Real-World Bank Cloud Migrations"
                    Style="{StaticResource TitleTextBlockStyle}"/>

            <!-- Capital One -->
            <StackPanel Orientation="Horizontal"
                    Spacing="16"
                    VerticalAlignment="Center">
                <Image Source="https://upload.wikimedia.org/wikipedia/commons/7/7a/Capital_One_logo.svg"
                        Height="48"
                        Width="120"
                        Stretch="Uniform"/>
                <StackPanel>
                    <TextBlock Text="Capital One"
                            Style="{StaticResource SubtitleTextBlockStyle}"/>
                    <TextBlock Text="Cloud Provider: AWS"/>
                    <TextBlock Text="Capital One was one of the first major U.S. banks to go all-in on AWS, migrating core workloads and closing data centers to improve agility, security, and innovation."
                            TextWrapping="Wrap"/>
                </StackPanel>
            </StackPanel>

            <!-- BBVA -->
            <StackPanel Orientation="Horizontal"
                    Spacing="16"
                    VerticalAlignment="Center">
                <Image Source="https://upload.wikimedia.org/wikipedia/commons/6/6b/BBVA_2019_logo.svg"
                        Height="48"
                        Width="120"
                        Stretch="Uniform"/>
                <StackPanel>
                    <TextBlock Text="BBVA"
                            Style="{StaticResource SubtitleTextBlockStyle}"/>
                    <TextBlock Text="Cloud Providers: Azure, AWS"/>
                    <TextBlock Text="BBVA adopted cloud solutions to accelerate digital transformation, enhance customer experience, and drive innovation in financial services."
                            TextWrapping="Wrap"/>
                </StackPanel>
            </StackPanel>

            <!-- NAB -->
            <StackPanel Orientation="Horizontal"
                    Spacing="16"
                    VerticalAlignment="Center">
                <Image Source="https://upload.wikimedia.org/wikipedia/commons/2/2e/National_Australia_Bank_logo.svg"
                        Height="48"
                        Width="120"
                        Stretch="Uniform"/>
                <StackPanel>
                    <TextBlock Text="National Australia Bank (NAB)"
                            Style="{StaticResource SubtitleTextBlockStyle}"/>
                    <TextBlock Text="Cloud Provider: AWS"/>
                    <TextBlock Text="NAB moved core banking services to AWS, enabling faster product development and improved operational resilience."
                            TextWrapping="Wrap"/>
                </StackPanel>
            </StackPanel>

            <!-- Deutsche Bank -->
            <StackPanel Orientation="Horizontal"
                    Spacing="16"
                    VerticalAlignment="Center">
                <Image Source="https://upload.wikimedia.org/wikipedia/commons/0/0e/Deutsche_Bank_logo_without_wordmark.svg"
                        Height="48"
                        Width="48"
                        Stretch="Uniform"/>
                <StackPanel>
                    <TextBlock Text="Deutsche Bank"
                            Style="{StaticResource SubtitleTextBlockStyle}"/>
                    <TextBlock Text="Cloud Provider: Google Cloud"/>
                    <TextBlock Text="Deutsche Bank partnered with Google Cloud to modernize IT infrastructure and co-innovate new financial products and services."
                            TextWrapping="Wrap"/>
                </StackPanel>
            </StackPanel>

            <!-- ABN AMRO -->
            <StackPanel Orientation="Horizontal"
                    Spacing="16"
                    VerticalAlignment="Center">
                <Image Source="https://upload.wikimedia.org/wikipedia/commons/2/2a/ABN_AMRO_logo.svg"
                        Height="48"
                        Width="48"
                        Stretch="Uniform"/>
                <StackPanel>
                    <TextBlock Text="ABN AMRO"
                            Style="{StaticResource SubtitleTextBlockStyle}"/>
                    <TextBlock Text="Cloud Provider: Azure"/>
                    <TextBlock Text="ABN AMRO uses Azure for analytics, digital banking, and to accelerate its cloud-first strategy."
                            TextWrapping="Wrap"/>
                </StackPanel>
            </StackPanel>

            <TextBlock Text="Logos are property of their respective companies and used here for informational purposes only."
                    FontStyle="Italic"
                    FontSize="12"/>
        </StackPanel>
    </ScrollViewer>
</Page>
