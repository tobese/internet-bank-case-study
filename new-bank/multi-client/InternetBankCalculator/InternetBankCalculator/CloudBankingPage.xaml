<Page
    x:Class="InternetBankCalculator.CloudBankingPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="#F5F7FA">

    <ScrollViewer>
        <StackPanel Spacing="24"
                    Margin="24">
            <TextBlock Text="Cloud Banking: Real-World Bank Cloud Migrations"
                       Style="{StaticResource TitleTextBlockStyle}"/>

            <!-- Bank Table -->
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Capital One -->
                <Image Grid.Row="0"
                        Grid.Column="0"
                        Source="Assets/BankLogos/CapitalOneHQ_body.jpg"
                        Height="48"
                        Width="120"
                        Stretch="Uniform"
                        VerticalAlignment="Top"
                        Margin="0,8,8,8"/>
                <StackPanel Grid.Row="0"
                        Grid.Column="1"
                        VerticalAlignment="Center">
                    <TextBlock Text="Capital One"
                            Style="{StaticResource SubtitleTextBlockStyle}"/>
                    <TextBlock Text="Cloud Provider: AWS"/>
                    <TextBlock Text="Capital One was one of the first major U.S. banks to go all-in on AWS, migrating core workloads and closing data centers to improve agility, security, and innovation."
                            TextWrapping="Wrap"/>
                </StackPanel>

                <!-- BBVA -->
                <Image Grid.Row="1"
                        Grid.Column="0"
                        Source="Assets/BankLogos/Bilbao_-_BBVA_(ex_Banco_de_Comercio)_2.jpg"
                        Height="48"
                        Width="120"
                        Stretch="Uniform"
                        VerticalAlignment="Top"
                        Margin="0,8,8,8"/>
                <StackPanel Grid.Row="1"
                        Grid.Column="1"
                        VerticalAlignment="Center">
                    <TextBlock Text="BBVA"
                            Style="{StaticResource SubtitleTextBlockStyle}"/>
                    <TextBlock Text="Cloud Providers: Azure, AWS"/>
                    <TextBlock Text="BBVA adopted cloud solutions to accelerate digital transformation, enhance customer experience, and drive innovation in financial services."
                            TextWrapping="Wrap"/>
                </StackPanel>

                <!-- NAB -->
                <Image Grid.Row="2"
                        Grid.Column="0"
                        Source="Assets/BankLogos/National_Australia_Bank_HQ_in_Melbourne_CBD.jpg"
                        Height="48"
                        Width="120"
                        Stretch="Uniform"
                        VerticalAlignment="Top"
                        Margin="0,8,8,8"/>
                <StackPanel Grid.Row="2"
                        Grid.Column="1"
                        VerticalAlignment="Center">
                    <TextBlock Text="National Australia Bank (NAB)"
                            Style="{StaticResource SubtitleTextBlockStyle}"/>
                    <TextBlock Text="Cloud Provider: AWS"/>
                    <TextBlock Text="NAB moved core banking services to AWS, enabling faster product development and improved operational resilience."
                            TextWrapping="Wrap"/>
                </StackPanel>

                <!-- Deutsche Bank -->
                <Image Grid.Row="3"
                        Grid.Column="0"
                        Source="Assets/BankLogos/Deutsche_Bank_Taunusanlage.jpg"
                        Height="48"
                        Width="48"
                        Stretch="Uniform"
                        VerticalAlignment="Top"
                        Margin="0,8,8,8"/>
                <StackPanel Grid.Row="3"
                        Grid.Column="1"
                        VerticalAlignment="Center">
                    <TextBlock Text="Deutsche Bank"
                            Style="{StaticResource SubtitleTextBlockStyle}"/>
                    <TextBlock Text="Cloud Provider: Google Cloud"/>
                    <TextBlock Text="Deutsche Bank partnered with Google Cloud to modernize IT infrastructure and co-innovate new financial products and services."
                            TextWrapping="Wrap"/>
                </StackPanel>

                <!-- ABN AMRO -->
                <Image Grid.Row="4"
                        Grid.Column="0"
                        Source="Assets/BankLogos/250px-ABN_AMRO4.jpg"
                        Height="48"
                        Width="48"
                        Stretch="Uniform"
                        VerticalAlignment="Top"
                        Margin="0,8,8,8"/>
                <StackPanel Grid.Row="4"
                        Grid.Column="1"
                        VerticalAlignment="Center">
                    <TextBlock Text="ABN AMRO"
                            Style="{StaticResource SubtitleTextBlockStyle}"/>
                    <TextBlock Text="Cloud Provider: Azure"/>
                    <TextBlock Text="ABN AMRO uses Azure for analytics, digital banking, and to accelerate its cloud-first strategy."
                            TextWrapping="Wrap"/>
                </StackPanel>
            </Grid>

            <TextBlock Text="Logos are property of their respective companies and used here for informational purposes only."
                       FontStyle="Italic"
                       FontSize="12"/>
        </StackPanel>
    </ScrollViewer>
</Page>
