<Page
    x:Class="InternetBankCalculator.AboutContent.CobolToModernPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:InternetBankCalculator"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer>
        <StackPanel Spacing="16"
                    Padding="24">
            <TextBlock Text="From COBOL to Java or C#"
                       FontSize="28"
                       FontWeight="Bold"
                       Margin="0,0,0,16"/>
            <TextBlock Text="A quick guide for COBOL programmers transitioning to modern object-oriented languages: Java and C#."
                       FontSize="16"
                       Margin="0,0,0,24"/>

            <TextBlock Text="1. Key Concepts"
                       FontWeight="Bold"
                       FontSize="18"/>
            <StackPanel>
                <TextBlock Text="Procedural vs Object-Oriented Programming"/>
                <TextBlock Text="Data Division vs Classes/Objects"/>
                <TextBlock Text="PERFORM vs Loops (for, while)"/>
                <TextBlock Text="IF/ELSE, EVALUATE vs if/else, switch/case"/>
                <TextBlock Text="File I/O: Sequential Files vs Streams/APIs"/>
                <TextBlock Text="Error Handling: RETURN-CODE vs Exceptions"/>
                <TextBlock Text="Batch Processing vs Event-Driven/Interactive"/>
            </StackPanel>

            <TextBlock Text="2. Syntax Comparison"
                       FontWeight="Bold"
                       FontSize="18"/>
            <StackPanel>
                <TextBlock Text="Variable Declarations"/>
                <TextBlock Text="COBOL: 01 CUSTOMER-NAME PIC X(30)."/>
                <TextBlock Text="Java: String customerName;"/>
                <TextBlock Text="C#: string customerName;"/>
                <TextBlock Text=""/>
                <TextBlock Text="Procedures/Methods"/>
                <TextBlock Text="COBOL: PERFORM CALCULATE-TOTAL."/>
                <TextBlock Text="Java: calculateTotal();"/>
                <TextBlock Text="C#: CalculateTotal();"/>
            </StackPanel>

            <TextBlock Text="3. Data Structures"
                       FontWeight="Bold"
                       FontSize="18"/>
            <StackPanel>
                <TextBlock Text="COBOL: Arrays (OCCURS), Records (GROUP ITEMS)"/>
                <TextBlock Text="Java/C#: Arrays, Lists, Classes"/>
            </StackPanel>

            <TextBlock Text="4. Modern Tools &amp; IDEs"
                       FontWeight="Bold"
                       FontSize="18"/>
            <StackPanel>
                <HyperlinkButton Content="IntelliJ IDEA (Java)"
                                 NavigateUri="https://www.jetbrains.com/idea/"/>
                <HyperlinkButton Content="Eclipse (Java)"
                                 NavigateUri="https://www.eclipse.org/"/>
                <HyperlinkButton Content="Visual Studio (C#)"
                                 NavigateUri="https://visualstudio.microsoft.com/"/>
                <HyperlinkButton Content="VS Code (Java/C#)"
                                 NavigateUri="https://code.visualstudio.com/"/>
            </StackPanel>

            <TextBlock Text="5. Migration Resources"
                       FontWeight="Bold"
                       FontSize="18"/>
            <StackPanel>
                <HyperlinkButton Content="Open Mainframe Project: COBOL Programming Course"
                                 NavigateUri="https://www.openmainframeproject.org/projects/cobol-programming-course"/>
                <HyperlinkButton Content="IBM: Modernizing with Java"
                                 NavigateUri="https://www.ibm.com/cloud/learn/cobol-modernization"/>
                <HyperlinkButton Content="Microsoft: Mainframe to Azure"
                                 NavigateUri="https://learn.microsoft.com/en-us/azure/architecture/solution-ideas/articles/mainframe-migration"/>
            </StackPanel>

            <TextBlock Text="6. Sample Code Snippets"
                       FontWeight="Bold"
                       FontSize="18"/>
            <StackPanel>
                <TextBlock Text="COBOL: IF CUSTOMER-AGE > 18 THEN ..."/>
                <TextBlock Text="Java: if (customerAge > 18) { ... }"/>
                <TextBlock Text="C#: if (customerAge > 18) { ... }"/>
            </StackPanel>

            <TextBlock Text="7. Visual Reference"
                       FontWeight="Bold"
                       FontSize="18"/>
            <StackPanel>
                <Image Source="Assets/cobol_sample.png"
                       Height="120"/>
                <Image Source="Assets/java_sample.png"
                       Height="120"/>
                <Image Source="Assets/csharp_sample.png"
                       Height="120"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
