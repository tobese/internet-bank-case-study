<Page x:Class="InternetBankCalculator.AboutContent.FromJavaToCSharpPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F5F7FA">

    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="700"
                    HorizontalAlignment="Center"
                    Padding="24,60,24,60"
                    Spacing="24">

            <StackPanel Spacing="8">
                <TextBlock Text="From Java to C#"
                           FontSize="30"
                           FontWeight="Bold"
                           Foreground="#1A1A1A"/>
                <TextBlock Text="A curated guide to help senior Java developers quickly become productive C# developers."
                           FontSize="15"
                           Foreground="#555555"
                           TextWrapping="Wrap"/>
            </StackPanel>

            <TextBlock Text="1. Official Documentation and Guides"
                       FontWeight="Bold"
                       FontSize="18"/>
            <StackPanel>
                <HyperlinkButton Content="Microsoft C# Guide"
                                 NavigateUri="https://learn.microsoft.com/en-us/dotnet/csharp/"/>
                <HyperlinkButton Content=".NET Documentation"
                                 NavigateUri="https://learn.microsoft.com/en-us/dotnet/"/>
                <HyperlinkButton Content="C# for Java Developers (MSDN)"
                                 NavigateUri="https://learn.microsoft.com/en-us/dotnet/csharp/programming-guide/inside-a-program/csharp-for-java-developers"/>
                <HyperlinkButton Content=".NET Tour for Java Developers"
                                 NavigateUri="https://learn.microsoft.com/en-us/dotnet/core/tutorials/java-developers"/>
            </StackPanel>

            <TextBlock Text="2. Language Comparison Cheat Sheets"
                       FontWeight="Bold"
                       FontSize="18"/>
            <StackPanel>
                <HyperlinkButton Content="Java vs C# Syntax Cheat Sheet"
                                 NavigateUri="https://www.programmingnotes.org/684/java-vs-c-syntax-comparison-cheat-sheet/"/>
                <HyperlinkButton Content="Rosetta Code: Java"
                                 NavigateUri="https://rosettacode.org/wiki/Java"/>
                <HyperlinkButton Content="Rosetta Code: C#"
                                 NavigateUri="https://rosettacode.org/wiki/C_Sharp"/>
                <HyperlinkButton Content="C# for Java Developers (Comparison Table)"
                                 NavigateUri="https://learn.microsoft.com/en-us/dotnet/csharp/programming-guide/inside-a-program/csharp-for-java-developers#comparison-of-java-and-c-features"/>
            </StackPanel>

            <TextBlock Text="3. Key Concepts for Java Developers"
                       FontWeight="Bold"
                       FontSize="18"/>
            <StackPanel>
                <TextBlock Text=".NET Types vs Java Types"/>
                <TextBlock Text="Memory Management (GC, value/reference types)"/>
                <TextBlock Text="LINQ (Language Integrated Query) vs Streams/Collections"/>
                <TextBlock Text="Async/Await vs Java Futures/CompletableFuture"/>
                <TextBlock Text="Events &amp; Delegates vs Listeners"/>
                <TextBlock Text="Properties vs Getters/Setters"/>
                <TextBlock Text="NuGet vs Maven/Gradle"/>
                <TextBlock Text=".NET Project Structure (csproj, sln) vs Maven/Gradle"/>
                <TextBlock Text="Dependency Injection (Microsoft.Extensions.DependencyInjection)"/>
            </StackPanel>

            <TextBlock Text="4. Tools &amp; IDEs"
                       FontWeight="Bold"
                       FontSize="18"/>
            <StackPanel>
                <HyperlinkButton Content="Visual Studio (Windows/macOS)"
                                 NavigateUri="https://visualstudio.microsoft.com/"/>
                <HyperlinkButton Content="Visual Studio Documentation"
                                 NavigateUri="https://learn.microsoft.com/en-us/visualstudio/"/>
                <HyperlinkButton Content="Get Started Guide"
                                 NavigateUri="https://learn.microsoft.com/en-us/visualstudio/get-started/"/>
                <HyperlinkButton Content="Visual Studio for Mac"
                                 NavigateUri="https://learn.microsoft.com/en-us/visualstudio/mac/"/>
                <HyperlinkButton Content="IDE Tour"
                                 NavigateUri="https://learn.microsoft.com/en-us/visualstudio/ide/visual-studio-ide"/>
                <HyperlinkButton Content="Tips and Tricks"
                                 NavigateUri="https://learn.microsoft.com/en-us/visualstudio/ide/visual-studio-ide-tips-and-tricks"/>
                <HyperlinkButton Content="Keyboard Shortcuts"
                                 NavigateUri="https://learn.microsoft.com/en-us/visualstudio/ide/default-keyboard-shortcuts-in-visual-studio"/>
                <HyperlinkButton Content="Wikipedia"
                                 NavigateUri="https://en.wikipedia.org/wiki/Microsoft_Visual_Studio"/>
                <HyperlinkButton Content="Visual Studio Code (Cross-platform)"
                                 NavigateUri="https://code.visualstudio.com/"/>
                <HyperlinkButton Content="JetBrains Rider"
                                 NavigateUri="https://www.jetbrains.com/rider/"/>
                <HyperlinkButton Content=".NET CLI"
                                 NavigateUri="https://learn.microsoft.com/en-us/dotnet/core/tools/"/>
            </StackPanel>

            <TextBlock Text="5. Tutorials &amp; Hands-On Labs"
                       FontWeight="Bold"
                       FontSize="18"/>
            <StackPanel>
                <HyperlinkButton Content="C# 101 (Microsoft Learn)"
                                 NavigateUri="https://learn.microsoft.com/en-us/training/paths/csharp-first-steps/"/>
                <HyperlinkButton Content=".NET 101 (Microsoft Learn)"
                                 NavigateUri="https://learn.microsoft.com/en-us/training/paths/dotnet-beginner/"/>
                <HyperlinkButton Content=".NET for Apache Spark (Big Data)"
                                 NavigateUri="https://learn.microsoft.com/en-us/dotnet/spark/"/>
                <HyperlinkButton Content=".NET Interactive Notebooks"
                                 NavigateUri="https://github.com/dotnet/interactive"/>
            </StackPanel>

            <TextBlock Text="6. Community &amp; Q&amp;A"
                       FontWeight="Bold"
                       FontSize="18"/>
            <StackPanel>
                <HyperlinkButton Content="Stack Overflow: (c#)"
                                 NavigateUri="https://stackoverflow.com/questions/tagged/c%23"/>
                <HyperlinkButton Content=".NET Discord"
                                 NavigateUri="https://discord.com/invite/dotnet"/>
                <HyperlinkButton Content=".NET Foundation"
                                 NavigateUri="https://dotnetfoundation.org/community"/>
            </StackPanel>

            <TextBlock Text="7. Books"
                       FontWeight="Bold"
                       FontSize="18"/>
            <StackPanel>
                <TextBlock Text="C# 12 in a Nutshell (O'Reilly)"/>
                <TextBlock Text="Pro C# 12 with .NET 8 (Apress)"/>
                <TextBlock Text="C# 12 and .NET 8 - Modern Cross-Platform Development (Packt)"/>
            </StackPanel>

            <TextBlock Text="8. Migration &amp; Interop"
                       FontWeight="Bold"
                       FontSize="18"/>
            <StackPanel>
                <HyperlinkButton Content="Telerik Converter"
                                 NavigateUri="https://converter.telerik.com/"/>
                <HyperlinkButton Content="CarlosAG Code Translator"
                                 NavigateUri="https://www.carlosag.net/tools/codetranslator/"/>
                <HyperlinkButton Content=".NET Native Interop"
                                 NavigateUri="https://learn.microsoft.com/en-us/dotnet/standard/native-interop/"/>
            </StackPanel>

            <TextBlock Text="9. Videos &amp; Playlists"
                       FontWeight="Bold"
                       FontSize="18"/>
            <StackPanel>
                <HyperlinkButton Content="C# for Java Developers (YouTube)"
                                 NavigateUri="https://www.youtube.com/results?search_query=c%23+for+java+developers"/>
                <HyperlinkButton Content=".NET Conf Sessions"
                                 NavigateUri="https://www.dotnetconf.net/"/>
            </StackPanel>

            <TextBlock Text="10. Meet Your AI Coding Assistant"
                       FontWeight="Bold"
                       FontSize="18"/>
            <StackPanel Orientation="Horizontal"
                        Spacing="16">
                <Image Source="ms-appx:///Assets/copiloticon.png"
                       Width="64"
                       Height="64"/>
                <StackPanel>
                    <TextBlock Text="GitHub Copilot is your expert AI programming assistant, ready to help you:"/>
                    <TextBlock Text="• Onboard to new languages and frameworks lightning-fast"/>
                    <TextBlock Text="• Refactor, debug, and modernize codebases"/>
                    <TextBlock Text="• Automate repetitive tasks and boost productivity"/>
                    <TextBlock Text="• Integrate best practices and official docs into your workflow"/>
                    <TextBlock Text="• Answer questions, generate code, and guide you step-by-step"/>
                    <TextBlock Text="Ask for help anytime - Copilot is always ready to assist!"
                               FontStyle="Italic"/>
                </StackPanel>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Page>
