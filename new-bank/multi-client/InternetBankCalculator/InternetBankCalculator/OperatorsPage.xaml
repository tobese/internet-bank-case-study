<Page x:Class="InternetBankCalculator.OperatorsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F5F7FA">

    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="700"
                    HorizontalAlignment="Center"
                    Padding="24,60,24,60"
                    Spacing="24">

            <StackPanel Spacing="8">
                <TextBlock Text="About"
                           FontSize="30"
                           FontWeight="Bold"
                           Foreground="#1A1A1A"/>
                <TextBlock Text="Dogger Bank is a fictitious internet bank — a case study demonstrating the latest and greatest in cloud-native technology, from a C# / WebAssembly frontend to a Java API running on Kubernetes in the cloud."
                           FontSize="15"
                           Foreground="#555555"
                           TextWrapping="Wrap"/>
            </StackPanel>

            <!-- Tech stack -->
            <Border Background="#1A1A2E"
                    CornerRadius="12"
                    Padding="28">
                <StackPanel Spacing="20">
                    <TextBlock Text="Tech Stack"
                               FontSize="17"
                               FontWeight="SemiBold"
                               Foreground="White"/>

                    <!-- Row 1: Uno + Spring Boot -->
                    <StackPanel Orientation="Horizontal"
                                Spacing="16">
                        <Border Background="White"
                                CornerRadius="8"
                                Padding="10,8"
                                Width="120">
                            <StackPanel Spacing="6"
                                        HorizontalAlignment="Center">
                                <Image Source="ms-appx:///Assets/logo_uno.png"
                                       Height="38"
                                       Stretch="Uniform"
                                       HorizontalAlignment="Center"/>
                                <TextBlock Text="Uno Platform"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="#1A1A1A"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"/>
                                <TextBlock Text="WASM · C# / XAML"
                                           FontSize="10"
                                           Foreground="#555555"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                        <Border Background="White"
                                CornerRadius="8"
                                Padding="10,8"
                                Width="120">
                            <StackPanel Spacing="6"
                                        HorizontalAlignment="Center">
                                <TextBlock Text="☕"
                                           FontSize="36"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Spring Boot 3"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="#1A1A1A"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"/>
                                <TextBlock Text="Java 21 · REST API"
                                           FontSize="10"
                                           Foreground="#555555"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                        <Border Background="White"
                                CornerRadius="8"
                                Padding="10,8"
                                Width="120">
                            <StackPanel Spacing="6"
                                        HorizontalAlignment="Center">
                                <Image Source="ms-appx:///Assets/logo_postgres.png"
                                       Height="38"
                                       Stretch="Uniform"
                                       HorizontalAlignment="Center"/>
                                <TextBlock Text="PostgreSQL 17"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="#1A1A1A"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"/>
                                <TextBlock Text="Primary database"
                                           FontSize="10"
                                           Foreground="#555555"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Row 2: Docker + Kubernetes + Redis -->
                    <StackPanel Orientation="Horizontal"
                                Spacing="16">
                        <Border Background="White"
                                CornerRadius="8"
                                Padding="10,8"
                                Width="120">
                            <StackPanel Spacing="6"
                                        HorizontalAlignment="Center">
                                <Image Source="ms-appx:///Assets/logo_docker.png"
                                       Height="38"
                                       Stretch="Uniform"
                                       HorizontalAlignment="Center"/>
                                <TextBlock Text="Docker"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="#1A1A1A"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"/>
                                <TextBlock Text="Local Compose stack"
                                           FontSize="10"
                                           Foreground="#555555"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                        <Border Background="White"
                                CornerRadius="8"
                                Padding="10,8"
                                Width="120">
                            <StackPanel Spacing="6"
                                        HorizontalAlignment="Center">
                                <Image Source="ms-appx:///Assets/logo_kubernetes_spin.gif"
                                       Height="38"
                                       Stretch="Uniform"
                                       HorizontalAlignment="Center"/>
                                <TextBlock Text="Kubernetes"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="#1A1A1A"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"/>
                                <TextBlock Text="AWS EKS · HPA · PDB"
                                           FontSize="10"
                                           Foreground="#555555"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                        <Border Background="White"
                                CornerRadius="8"
                                Padding="10,8"
                                Width="120">
                            <StackPanel Spacing="6"
                                        HorizontalAlignment="Center">
                                <TextBlock Text="⚡"
                                           FontSize="36"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Redis 7"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="#1A1A1A"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"/>
                                <TextBlock Text="Primes cache · 24 h TTL"
                                           FontSize="10"
                                           Foreground="#555555"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Row 3: Observability -->
                    <StackPanel Orientation="Horizontal"
                                Spacing="16">
                        <Border Background="White"
                                CornerRadius="8"
                                Padding="10,8"
                                Width="120">
                            <StackPanel Spacing="6"
                                        HorizontalAlignment="Center">
                                <TextBlock Text="📊"
                                           FontSize="36"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Prometheus"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="#1A1A1A"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"/>
                                <TextBlock Text="Metrics · PromQL"
                                           FontSize="10"
                                           Foreground="#555555"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                        <Border Background="White"
                                CornerRadius="8"
                                Padding="10,8"
                                Width="120">
                            <StackPanel Spacing="6"
                                        HorizontalAlignment="Center">
                                <TextBlock Text="🔥"
                                           FontSize="36"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Grafana"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="#1A1A1A"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"/>
                                <TextBlock Text="Dashboards · Loki · Tempo"
                                           FontSize="10"
                                           Foreground="#555555"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                        <Border Background="White"
                                CornerRadius="8"
                                Padding="10,8"
                                Width="120">
                            <StackPanel Spacing="6"
                                        HorizontalAlignment="Center">
                                <TextBlock Text="🔭"
                                           FontSize="36"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="OpenTelemetry"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="#1A1A1A"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"/>
                                <TextBlock Text="Traces · Logs · Metrics"
                                           FontSize="10"
                                           Foreground="#555555"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
