<Page x:Class="InternetBankCalculator.OperatorsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F5F7FA">

    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="700"
                    HorizontalAlignment="Center"
                    Padding="24,60,24,60"
                    Spacing="24">

            <StackPanel Spacing="8">
                <TextBlock Text="About"
                           FontSize="30"
                           FontWeight="Bold"
                           Foreground="#1A1A1A"/>
                <TextBlock Text="Dogger Bank is a fictitious internet bank — a case study demonstrating the latest and greatest in cloud-native technology, from a C# / WebAssembly frontend to a Java API running on Kubernetes in the cloud."
                           FontSize="15"
                           Foreground="#555555"
                           TextWrapping="Wrap"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Page>
