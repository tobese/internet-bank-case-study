<Page x:Class="InternetBankCalculator.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:InternetBankCalculator"
      Background="#F5F7FA">

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <ScrollViewer Grid.Row="0"
                  HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
      <Grid>
        <Grid Grid.Row="0"
              HorizontalAlignment="Center"
              Padding="20,60,20,40"
              MaxWidth="460">

          <!-- Card -->
          <Border Background="White"
                  CornerRadius="12"
                  Padding="32"
                  BorderBrush="#E0E0E0"
                  BorderThickness="0"
                  HorizontalAlignment="Stretch">
            <Border.Shadow>
              <ThemeShadow/>
            </Border.Shadow>

            <StackPanel Spacing="0">

              <!-- Logo -->
              <Image Source="ms-appx:///Assets/doggerbank.png"
                     MaxWidth="300"
                     Stretch="Uniform"
                     HorizontalAlignment="Center"
                     Margin="0,0,0,20"/>

              <!-- Abacus -->
              <Image Source="https://static.wikia.nocookie.net/computerscience/images/c/cf/Abacus.jpg/revision/latest?cb=20140901191838"
                     MaxWidth="48"
                     Stretch="Uniform"
                     HorizontalAlignment="Center"
                     Margin="0,0,0,4"/>

              <!-- Title -->
              <TextBlock Text="Internet Banking Calculator"
                         FontSize="22"
                         FontWeight="SemiBold"
                         Margin="0,0,0,4"/>

              <!-- Subtitle -->
              <TextBlock Text="Arithmetic, factorial &amp; Fibonacci – powered by the Java Math API"
                         FontSize="13"
                         Foreground="#666666"
                         Margin="0,0,0,24"
                         TextWrapping="Wrap"/>

              <!-- Expression label -->
              <TextBlock Text="Expression"
                         FontWeight="SemiBold"
                         Margin="0,0,0,6"/>

              <!-- Expression input -->
              <TextBox x:Name="ExpressionInput"
                       Text="{Binding Expression, Mode=TwoWay}"
                       IsEnabled="{Binding IsInputEnabled}"
                       PlaceholderText="e.g. 3 + 4, fac(5), fib(10)"
                       KeyDown="ExpressionInput_KeyDown"
                       Padding="10,10,10,10"
                       FontSize="16"
                       BorderBrush="#CCCCCC"
                       CornerRadius="8"/>

              <!-- Action buttons -->
              <Grid Margin="0,12,0,0"
                    ColumnSpacing="8"
                    RowSpacing="8">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Button x:Name="BtnCalc"
                        Content="Calculate"
                        Command="{Binding Calculate}"
                        IsEnabled="{Binding IsInputEnabled}"
                        Grid.Column="0"
                        HorizontalAlignment="Stretch"
                        Background="{StaticResource ButtonCalculateBackground}"
                        Foreground="{StaticResource ButtonForeground}"
                        FontWeight="SemiBold"
                        Padding="10"
                        CornerRadius="8">
                  <Button.Resources>
                    <SolidColorBrush x:Key="ButtonBackgroundPointerOver"
                                     Color="#3A7FC9"/>
                    <SolidColorBrush x:Key="ButtonBackgroundPressed"
                                     Color="#2A6CB8"/>
                    <SolidColorBrush x:Key="ButtonForegroundPointerOver"
                                     Color="White"/>
                    <SolidColorBrush x:Key="ButtonForegroundPressed"
                                     Color="White"/>
                  </Button.Resources>
                </Button>

                <Button x:Name="BtnFac"
                        Content="fac(n)"
                        Command="{Binding CalculateFactorial}"
                        IsEnabled="{Binding IsInputEnabled}"
                        Grid.Column="1"
                        HorizontalAlignment="Stretch"
                        Background="{StaticResource ButtonFacBackground}"
                        Foreground="{StaticResource ButtonForeground}"
                        FontWeight="SemiBold"
                        Padding="10"
                        CornerRadius="8">
                  <Button.Resources>
                    <SolidColorBrush x:Key="ButtonBackgroundPointerOver"
                                     Color="#279845"/>
                    <SolidColorBrush x:Key="ButtonBackgroundPressed"
                                     Color="#1A8338"/>
                    <SolidColorBrush x:Key="ButtonForegroundPointerOver"
                                     Color="White"/>
                    <SolidColorBrush x:Key="ButtonForegroundPressed"
                                     Color="White"/>
                  </Button.Resources>
                </Button>

                <Button x:Name="BtnFib"
                        Content="fib(n)"
                        Command="{Binding CalculateFibonacci}"
                        IsEnabled="{Binding IsInputEnabled}"
                        Grid.Column="2"
                        HorizontalAlignment="Stretch"
                        Background="{StaticResource ButtonFibBackground}"
                        Foreground="{StaticResource ButtonForeground}"
                        FontWeight="SemiBold"
                        Padding="10"
                        CornerRadius="8">
                  <Button.Resources>
                    <SolidColorBrush x:Key="ButtonBackgroundPointerOver"
                                     Color="#006E7A"/>
                    <SolidColorBrush x:Key="ButtonBackgroundPressed"
                                     Color="#005A65"/>
                    <SolidColorBrush x:Key="ButtonForegroundPointerOver"
                                     Color="White"/>
                    <SolidColorBrush x:Key="ButtonForegroundPressed"
                                     Color="White"/>
                  </Button.Resources>
                </Button>

                <Button x:Name="BtnPrimes"
                        Content="Primes(n)"
                        Command="{Binding StreamPrimes}"
                        IsEnabled="{Binding IsInputEnabled}"
                        Grid.Row="1"
                        Grid.Column="0"
                        Grid.ColumnSpan="3"
                        HorizontalAlignment="Stretch"
                        Background="#5B4FCF"
                        Foreground="White"
                        FontWeight="SemiBold"
                        Padding="10"
                        CornerRadius="8">
                  <Button.Resources>
                    <SolidColorBrush x:Key="ButtonBackgroundPointerOver"
                                     Color="#4B3FBF"/>
                    <SolidColorBrush x:Key="ButtonBackgroundPressed"
                                     Color="#3B2FAF"/>
                    <SolidColorBrush x:Key="ButtonForegroundPointerOver"
                                     Color="White"/>
                    <SolidColorBrush x:Key="ButtonForegroundPressed"
                                     Color="White"/>
                  </Button.Resources>
                </Button>
              </Grid>

              <Border x:Name="ResultBorder"
                      Background="{Binding IsError, Converter={StaticResource BoolToBackgroundConverter}}"
                      CornerRadius="8"
                      Padding="14"
                      Margin="0,20,0,0"
                      MinHeight="48">
                <StackPanel Orientation="Horizontal"
                            Spacing="10"
                            VerticalAlignment="Center">
                  <ProgressRing IsActive="{Binding IsLoading}"
                                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"
                                Width="20"
                                Height="20"
                                Foreground="#4A90D9"/>
                  <TextBlock x:Name="ResultText"
                             Text="{Binding Result}"
                             Foreground="{Binding IsError, Converter={StaticResource BoolToForegroundConverter}}"
                             TextWrapping="Wrap"
                             VerticalAlignment="Center"/>
                </StackPanel>
              </Border>

              <!-- Primes streaming result -->
              <Border Background="#F3F0FF"
                      CornerRadius="8"
                      Padding="14"
                      Margin="0,12,0,0">
                <StackPanel>
                  <StackPanel Orientation="Horizontal"
                              Spacing="8"
                              Margin="0,0,0,6">
                    <TextBlock Text="Primes (Sieve of Eratosthenes)"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="#5B4FCF"
                               VerticalAlignment="Center"/>
                    <ProgressRing IsActive="{Binding IsPrimesRunning}"
                                  Visibility="{Binding IsPrimesRunning, Converter={StaticResource BoolToVisibilityConverter}}"
                                  Width="14"
                                  Height="14"
                                  Foreground="#5B4FCF"/>
                  </StackPanel>
                  <TextBlock Text="{Binding PrimesResult}"
                             Foreground="#2D2060"
                             TextWrapping="Wrap"
                             FontFamily="Consolas, Courier New, monospace"/>
                </StackPanel>
              </Border>

              <!-- History -->
              <Border BorderBrush="#EEEEEE"
                      BorderThickness="0,1,0,0"
                      Margin="0,24,0,0"
                      Padding="0,16,0,0">
                <StackPanel>
                  <TextBlock Text="History"
                             FontSize="16"
                             FontWeight="SemiBold"
                             Margin="0,0,0,8"/>
                  <ListView x:Name="HistoryList"
                            MaxHeight="200"
                            ItemsSource="{Binding History}"
                            SelectionMode="None"
                            IsItemClickEnabled="False">
                    <ListView.ItemTemplate>
                      <DataTemplate>
                        <TextBlock Text="{Binding}"
                                   FontSize="14"
                                   Foreground="#444444"
                                   Padding="0,4,0,4"/>
                      </DataTemplate>
                    </ListView.ItemTemplate>
                  </ListView>
                </StackPanel>
              </Border>

            </StackPanel>
          </Border>
        </Grid>
      </Grid>
    </ScrollViewer>

    <!-- Mathematician of the day footer -->
    <Border Grid.Row="1"
            Background="#1A1A2E"
            Padding="20,14,20,14">
      <StackPanel Orientation="Horizontal"
                  Spacing="12"
                  HorizontalAlignment="Center">
        <TextBlock Text="🎓 Mathematician of the day:"
                   Foreground="#AAAACC"
                   FontSize="13"
                   VerticalAlignment="Center"/>
        <StackPanel>
          <TextBlock Text="{Binding DailyMathematician.Name}"
                     Foreground="White"
                     FontWeight="SemiBold"
                     FontSize="13"/>
          <TextBlock Text="{Binding DailyMathematician.Era}"
                     Foreground="#AAAACC"
                     FontSize="11"/>
        </StackPanel>
        <TextBlock Text="{Binding DailyMathematician.Description}"
                   Foreground="#CCCCDD"
                   FontSize="12"
                   MaxWidth="500"
                   TextWrapping="Wrap"
                   VerticalAlignment="Center"/>
      </StackPanel>
    </Border>

  </Grid>
</Page>
