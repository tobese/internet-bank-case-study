<Page x:Class="InternetBankCalculator.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:InternetBankCalculator"
      Background="#F5F7FA">

  <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
    <Grid HorizontalAlignment="Center" Padding="20,60,20,40" MaxWidth="460">

      <!-- Card -->
      <Border Background="White" CornerRadius="12" Padding="32"
              BorderBrush="#E0E0E0" BorderThickness="0"
              HorizontalAlignment="Stretch">
        <Border.Shadow>
          <ThemeShadow />
        </Border.Shadow>

        <StackPanel Spacing="0">

          <!-- Logo -->
          <Image Source="ms-appx:///Assets/doggerbank.png"
                 MaxWidth="300" Stretch="Uniform"
                 HorizontalAlignment="Center" Margin="0,0,0,20" />

          <!-- Title -->
          <TextBlock Text="Internet Banking Calculator"
                     FontSize="22" FontWeight="SemiBold"
                     Margin="0,0,0,4" />

          <!-- Subtitle -->
          <TextBlock Text="Arithmetic, factorial &amp; Fibonacci – powered by the Java Math API"
                     FontSize="13" Foreground="#666666"
                     Margin="0,0,0,24" TextWrapping="Wrap" />

          <!-- Expression label -->
          <TextBlock Text="Expression" FontWeight="SemiBold" Margin="0,0,0,6" />

          <!-- Expression input -->
          <TextBox x:Name="ExpressionInput"
                   PlaceholderText="e.g. 3 + 4, fac(5), fib(10)"
                   KeyDown="ExpressionInput_KeyDown"
                   Padding="10,10,10,10" FontSize="16"
                   BorderBrush="#CCCCCC" CornerRadius="8" />

          <!-- Action buttons -->
          <Grid Margin="0,12,0,0" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Button x:Name="BtnCalc" Content="Calculate" Click="BtnCalc_Click"
                    Grid.Column="0" HorizontalAlignment="Stretch"
                    Background="#4A90D9" Foreground="White"
                    FontWeight="SemiBold" Padding="10" CornerRadius="8" />

            <Button x:Name="BtnFac" Content="fac(n)" Click="BtnFac_Click"
                    Grid.Column="1" HorizontalAlignment="Stretch"
                    Background="#34A853" Foreground="White"
                    FontWeight="SemiBold" Padding="10" CornerRadius="8" />

            <Button x:Name="BtnFib" Content="fib(n)" Click="BtnFib_Click"
                    Grid.Column="2" HorizontalAlignment="Stretch"
                    Background="#F9A825" Foreground="White"
                    FontWeight="SemiBold" Padding="10" CornerRadius="8" />
          </Grid>

          <!-- Result box -->
          <Border x:Name="ResultBorder" Background="#F0F4F8" CornerRadius="8"
                  Padding="14" Margin="0,20,0,0" MinHeight="48">
            <TextBlock x:Name="ResultText" Text="Enter an expression above"
                       FontSize="17" TextWrapping="Wrap" />
          </Border>

          <!-- History -->
          <Border BorderBrush="#EEEEEE" BorderThickness="0,1,0,0"
                  Margin="0,24,0,0" Padding="0,16,0,0">
            <StackPanel>
              <TextBlock Text="History" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8" />
              <ListView x:Name="HistoryList" MaxHeight="200"
                        SelectionMode="None" IsItemClickEnabled="False">
                <ListView.ItemTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding}" FontSize="14" Foreground="#444444"
                               Padding="0,4,0,4" />
                  </DataTemplate>
                </ListView.ItemTemplate>
              </ListView>
            </StackPanel>
          </Border>

        </StackPanel>
      </Border>
    </Grid>
  </ScrollViewer>
</Page>
