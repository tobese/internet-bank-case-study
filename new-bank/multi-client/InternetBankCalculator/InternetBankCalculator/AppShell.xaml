<Page
    x:Class="InternetBankCalculator.AppShell"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:InternetBankCalculator"
    xmlns:utu="using:Uno.Toolkit.UI"
    Background="{ThemeResource BackgroundBrush}">
    <utu:ExtendedSplashScreen x:Name="Splash">
        <utu:ExtendedSplashScreen.LoadingContent>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="2*" />
                    <RowDefinition />
                </Grid.RowDefinitions>
                <Image
                    Grid.Row="1"
                    Width="96"
                    Height="96"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Source="ms-appx:///Assets/logo_kubernetes_spin.gif"
                    Stretch="Uniform" />
                <TextBlock
                    Grid.Row="1"
                    Margin="16"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Bottom"
                    Style="{ThemeResource BodyLarge}"
                    Text="Doggerbank is spinning up" />
            </Grid>
        </utu:ExtendedSplashScreen.LoadingContent>
        <utu:ExtendedSplashScreen.Content>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!--  Top nav bar  -->
                <Border
                    Grid.Row="0"
                    Padding="16,0,16,0"
                    Background="{ThemeResource SurfaceInverseBrush}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!--  Logo  -->
                        <Button
                            x:Name="BtnHome"
                            Grid.Column="0"
                            Padding="0,12,24,12"
                            x:FieldModifier="public"
                            Background="Transparent"
                            BorderThickness="0"
                            Click="BtnHome_Click">
                            <Image
                                MaxHeight="28"
                                Source="ms-appx:///Assets/doggerbank.png"
                                Stretch="Uniform" />
                        </Button>

                        <!--  Nav links  -->
                        <Grid Grid.Column="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel
                                Grid.Column="0"
                                VerticalAlignment="Center"
                                Orientation="Horizontal"
                                Spacing="4">
                                <Button
                                    x:Name="BtnCalc"
                                    x:FieldModifier="public"
                                    Click="BtnCalc_Click"
                                    Content="Calculator"
                                    Style="{StaticResource NavButtonStyle}"
                                    ToolTipService.ToolTip="Go to Calculator page" />
                                <Button
                                    x:Name="BtnSystemDesign"
                                    x:FieldModifier="public"
                                    Click="BtnSystemDesign_Click"
                                    Content="System Design"
                                    Style="{StaticResource NavButtonStyle}"
                                    ToolTipService.ToolTip="View System Design" />
                                <Button
                                    x:Name="BtnAbout"
                                    x:FieldModifier="public"
                                    Click="BtnAbout_Click"
                                    Content="About"
                                    Style="{StaticResource NavButtonStyle}"
                                    ToolTipService.ToolTip="About this app" />
                            </StackPanel>
                            <!--  Reload button  -->
                            <Button
                                x:Name="BtnReload"
                                Grid.Column="1"
                                Padding="10,6"
                                x:FieldModifier="public"
                                Click="BtnReload_Click"
                                Content="⟳"
                                FontSize="18"
                                Style="{StaticResource NavButtonStyle}"
                                ToolTipService.ToolTip="Reload page" />
                        </Grid>
                    </Grid>
                </Border>

                <!--  Content area  -->
                <Frame
                    x:Name="ContentFrame"
                    Grid.Row="1"
                    x:FieldModifier="public" />
                <!--  Hidden dev button for Uprising slideshow navigation  -->
                <Button
                    x:Name="BtnUprisingHidden"
                    x:FieldModifier="public"
                    Click="BtnUprisingHidden_Click"
                    Content="Uprising"
                    Visibility="Collapsed" />

                <!--  Mathematician of the day footer  -->
                <Border
                    Grid.Row="2"
                    Padding="20,14,20,14"
                    Background="{ThemeResource SurfaceInverseBrush}">
                    <Grid>
                    <StackPanel
                        HorizontalAlignment="Center"
                        Orientation="Horizontal"
                        Spacing="12">
                        <TextBlock
                            VerticalAlignment="Center"
                            Foreground="{ThemeResource OnSurfaceInverseBrush}"
                            Style="{ThemeResource LabelMedium}"
                            Text="🎓 Mathematician of the day:" />
                        <StackPanel>
                            <TextBlock
                                Foreground="White"
                                Style="{ThemeResource LabelMedium}"
                                Text="{Binding DailyMathematician.Name}" />
                            <TextBlock
                                Foreground="{ThemeResource OnSurfaceInverseBrush}"
                                Style="{ThemeResource LabelSmall}"
                                Text="{Binding DailyMathematician.Era}" />
                        </StackPanel>
                        <TextBlock
                            MaxWidth="500"
                            VerticalAlignment="Center"
                            Foreground="{ThemeResource OnSurfaceInverseBrush}"
                            Style="{ThemeResource BodySmall}"
                            Text="{Binding DailyMathematician.Description}"
                            TextWrapping="Wrap" />
                    </StackPanel>
                    <TextBlock
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Foreground="{ThemeResource OnSurfaceInverseBrush}"
                        Opacity="0.5"
                        Style="{ThemeResource LabelSmall}"
                        Text="{x:Bind AppVersion}" />
                    </Grid>
                </Border>
            </Grid>
        </utu:ExtendedSplashScreen.Content>
    </utu:ExtendedSplashScreen>
</Page>
