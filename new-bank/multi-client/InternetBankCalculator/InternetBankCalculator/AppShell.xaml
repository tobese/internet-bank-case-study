<Page x:Class="InternetBankCalculator.AppShell"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:InternetBankCalculator"
      xmlns:utu="using:Uno.Toolkit.UI"
      Background="#F5F7FA">
    <utu:ExtendedSplashScreen x:Name="Splash">
        <utu:ExtendedSplashScreen.LoadingContent>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="2*"/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <Image Grid.Row="1"
                       Source="ms-appx:///Assets/logo_kubernetes_spin.gif"
                       Width="96"
                       Height="96"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       Stretch="Uniform"/>
                <TextBlock Text="Doggerbank is spinning up"
                           Grid.Row="1"
                           Margin="16"
                           FontSize="16"
                           VerticalAlignment="Bottom"
                           HorizontalAlignment="Center"/>
            </Grid>
        </utu:ExtendedSplashScreen.LoadingContent>
        <utu:ExtendedSplashScreen.Content>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Top nav bar -->
                <Border Grid.Row="0"
                        Background="#1A1A2E"
                        Padding="16,0,16,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Logo -->
                        <Button Grid.Column="0"
                                x:Name="BtnHome"
                                x:FieldModifier="public"
                                Click="BtnHome_Click"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="0,12,24,12">
                            <Image Source="ms-appx:///Assets/doggerbank.png"
                                   MaxHeight="28"
                                   Stretch="Uniform"/>
                        </Button>

                        <!-- Nav links -->
                        <Grid Grid.Column="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0"
                                        Orientation="Horizontal"
                                        Spacing="4"
                                        VerticalAlignment="Center">
                                <Button x:Name="BtnCalc"
                                        x:FieldModifier="public"
                                        Content="Calculator"
                                        Click="BtnCalc_Click"
                                        Style="{StaticResource NavButtonStyle}"
                                        ToolTipService.ToolTip="Go to Calculator page"/>
                                <Button x:Name="BtnSystemDesign"
                                        x:FieldModifier="public"
                                        Content="System Design"
                                        Click="BtnSystemDesign_Click"
                                        Style="{StaticResource NavButtonStyle}"
                                        ToolTipService.ToolTip="View System Design"/>
                                <Button x:Name="BtnAbout"
                                        x:FieldModifier="public"
                                        Content="About"
                                        Click="BtnAbout_Click"
                                        Style="{StaticResource NavButtonStyle}"
                                        ToolTipService.ToolTip="About this app"/>
                            </StackPanel>
                            <!-- Reload button -->
                            <Button Grid.Column="1"
                                    x:Name="BtnReload"
                                    x:FieldModifier="public"
                                    Content="⟳"
                                    Click="BtnReload_Click"
                                    ToolTipService.ToolTip="Reload page"
                                    Style="{StaticResource NavButtonStyle}"
                                    FontSize="18"
                                    Padding="10,6"/>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Content area -->
                <Frame x:Name="ContentFrame"
                       x:FieldModifier="public"
                       Grid.Row="1"/>
                <!-- Hidden dev button for Uprising slideshow navigation -->
                <Button x:Name="BtnUprisingHidden"
                        x:FieldModifier="public"
                        Content="Uprising"
                        Click="BtnUprisingHidden_Click"
                        Visibility="Collapsed"/>

                <!-- Mathematician of the day footer -->
                <Border Grid.Row="2"
                        Background="#1A1A2E"
                        Padding="20,14,20,14">
                    <StackPanel Orientation="Horizontal"
                                Spacing="12"
                                HorizontalAlignment="Center">
                        <TextBlock Text="🎓 Mathematician of the day:"
                                   Foreground="#AAAACC"
                                   FontSize="13"
                                   VerticalAlignment="Center"/>
                        <StackPanel>
                            <TextBlock Text="{Binding DailyMathematician.Name}"
                                       Foreground="White"
                                       FontWeight="SemiBold"
                                       FontSize="13"/>
                            <TextBlock Text="{Binding DailyMathematician.Era}"
                                       Foreground="#AAAACC"
                                       FontSize="11"/>
                        </StackPanel>
                        <TextBlock Text="{Binding DailyMathematician.Description}"
                                   Foreground="#CCCCDD"
                                   FontSize="12"
                                   MaxWidth="500"
                                   TextWrapping="Wrap"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </utu:ExtendedSplashScreen.Content>
    </utu:ExtendedSplashScreen>
</Page>
