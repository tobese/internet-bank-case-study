<Page
    x:Class="InternetBankCalculator.Pages.CalculatorPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:InternetBankCalculator"
    Background="{ThemeResource BackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer
            Grid.Row="0"
            HorizontalScrollBarVisibility="Disabled"
            VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid
                    Grid.Row="0"
                    MaxWidth="460"
                    Padding="20,60,20,40"
                    HorizontalAlignment="Center">

                    <!--  Card  -->
                    <Border
                        Padding="32"
                        HorizontalAlignment="Stretch"
                        Background="{ThemeResource SurfaceBrush}"
                        BorderBrush="{ThemeResource OutlineVariantBrush}"
                        BorderThickness="0"
                        CornerRadius="12">
                        <Border.Shadow>
                            <ThemeShadow />
                        </Border.Shadow>

                        <StackPanel Spacing="0">

                            <!--  Logo  -->
                            <Image
                                MaxWidth="300"
                                Margin="0,0,0,20"
                                HorizontalAlignment="Center"
                                Source="ms-appx:///Assets/doggerbank.png"
                                Stretch="Uniform" />

                            <!--  Abacus  -->
                            <Image
                                MaxWidth="48"
                                Margin="0,0,0,4"
                                HorizontalAlignment="Center"
                                Source="https://static.wikia.nocookie.net/computerscience/images/c/cf/Abacus.jpg/revision/latest?cb=20140901191838"
                                Stretch="Uniform" />

                            <!--  Title  -->
                            <TextBlock
                                Margin="0,0,0,4"
                                Style="{ThemeResource TitleLarge}"
                                Text="Internet Banking Calculator" />

                            <!--  Subtitle  -->
                            <TextBlock
                                Margin="0,0,0,24"
                                Foreground="{ThemeResource OnSurfaceVariantBrush}"
                                Style="{ThemeResource BodySmall}"
                                Text="Arithmetic, factorial &amp; Fibonacci – powered by the Java Math API"
                                TextWrapping="Wrap" />

                            <!--  Expression label  -->
                            <TextBlock
                                Margin="0,0,0,6"
                                FontWeight="SemiBold"
                                Text="Expression" />

                            <!--  Expression input  -->
                            <TextBox
                                x:Name="ExpressionInput"
                                Padding="10,10,10,10"
                                BorderBrush="#CCCCCC"
                                CornerRadius="8"
                                FontSize="16"
                                IsEnabled="{Binding IsInputEnabled}"
                                KeyDown="ExpressionInput_KeyDown"
                                PlaceholderText="e.g. 3 + 4, fac(5), fib(10)"
                                Text="{Binding Expression, Mode=TwoWay}" />

                            <!--  Action buttons  -->
                            <Grid
                                Margin="0,12,0,0"
                                ColumnSpacing="8"
                                RowSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Button
                                    x:Name="BtnCalc"
                                    Grid.Column="0"
                                    Padding="10"
                                    HorizontalAlignment="Stretch"
                                    Background="{StaticResource ButtonCalculateBackground}"
                                    Command="{Binding Calculate}"
                                    Content="Calculate"
                                    CornerRadius="8"
                                    FontWeight="SemiBold"
                                    Foreground="{StaticResource ButtonForeground}"
                                    IsEnabled="{Binding IsInputEnabled}" />

                                <Button
                                    x:Name="BtnFac"
                                    Grid.Column="1"
                                    Padding="10"
                                    HorizontalAlignment="Stretch"
                                    Background="{StaticResource ButtonFacBackground}"
                                    Command="{Binding CalculateFactorial}"
                                    Content="fac(n)"
                                    CornerRadius="8"
                                    FontWeight="SemiBold"
                                    Foreground="{StaticResource ButtonForeground}"
                                    IsEnabled="{Binding IsInputEnabled}">
                                    <Button.Resources>
                                        <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#279845" />
                                        <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#1A8338" />
                                        <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="White" />
                                        <SolidColorBrush x:Key="ButtonForegroundPressed" Color="White" />
                                    </Button.Resources>
                                </Button>

                                <Button
                                    x:Name="BtnFib"
                                    Grid.Column="2"
                                    Padding="10"
                                    HorizontalAlignment="Stretch"
                                    Background="{StaticResource ButtonFibBackground}"
                                    Command="{Binding CalculateFibonacci}"
                                    Content="fib(n)"
                                    CornerRadius="8"
                                    FontWeight="SemiBold"
                                    Foreground="{StaticResource ButtonForeground}"
                                    IsEnabled="{Binding IsInputEnabled}">
                                    <Button.Resources>
                                        <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#006E7A" />
                                        <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#005A65" />
                                        <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="White" />
                                        <SolidColorBrush x:Key="ButtonForegroundPressed" Color="White" />
                                    </Button.Resources>
                                </Button>

                                <Button
                                    x:Name="BtnPrimes"
                                    Grid.Row="1"
                                    Grid.Column="0"
                                    Grid.ColumnSpan="3"
                                    Padding="10"
                                    HorizontalAlignment="Stretch"
                                    Background="#5B4FCF"
                                    Command="{Binding StreamPrimes}"
                                    Content="Primes(n)"
                                    CornerRadius="8"
                                    FontWeight="SemiBold"
                                    Foreground="White"
                                    IsEnabled="{Binding IsInputEnabled}">
                                    <Button.Resources>
                                        <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#4B3FBF" />
                                        <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#3B2FAF" />
                                        <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="White" />
                                        <SolidColorBrush x:Key="ButtonForegroundPressed" Color="White" />
                                    </Button.Resources>
                                </Button>
                            </Grid>

                            <Border
                                x:Name="ResultBorder"
                                MinHeight="48"
                                Margin="0,20,0,0"
                                Padding="14"
                                Background="{Binding IsError, Converter={StaticResource BoolToBackgroundConverter}}"
                                CornerRadius="8">
                                <StackPanel
                                    VerticalAlignment="Center"
                                    Orientation="Horizontal"
                                    Spacing="10">
                                    <ProgressRing
                                        Width="20"
                                        Height="20"
                                        Foreground="#4A90D9"
                                        IsActive="{Binding IsLoading}"
                                        Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}" />
                                    <TextBlock
                                        x:Name="ResultText"
                                        VerticalAlignment="Center"
                                        Foreground="{Binding IsError, Converter={StaticResource BoolToForegroundConverter}}"
                                        Text="{Binding Result}"
                                        TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <!--  Primes streaming result  -->
                            <Border
                                Margin="0,12,0,0"
                                Padding="14"
                                Background="#F3F0FF"
                                CornerRadius="8">
                                <StackPanel>
                                    <StackPanel
                                        Margin="0,0,0,6"
                                        Orientation="Horizontal"
                                        Spacing="8">
                                        <TextBlock
                                            VerticalAlignment="Center"
                                            Foreground="#5B4FCF"
                                            Style="{ThemeResource LabelMedium}"
                                            Text="Primes (Sieve of Eratosthenes)" />
                                        <ProgressRing
                                            Width="14"
                                            Height="14"
                                            Foreground="#5B4FCF"
                                            IsActive="{Binding IsPrimesRunning}"
                                            Visibility="{Binding IsPrimesRunning, Converter={StaticResource BoolToVisibilityConverter}}" />
                                    </StackPanel>
                                    <TextBlock
                                        FontFamily="Consolas, Courier New, monospace"
                                        Foreground="#2D2060"
                                        Text="{Binding PrimesResult}"
                                        TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <!--  History  -->
                            <Border
                                Margin="0,24,0,0"
                                Padding="0,16,0,0"
                                BorderBrush="#EEEEEE"
                                BorderThickness="0,1,0,0">
                                <StackPanel>
                                    <TextBlock
                                        Margin="0,0,0,8"
                                        Style="{ThemeResource TitleMedium}"
                                        Text="History" />
                                    <ListView
                                        x:Name="HistoryList"
                                        MaxHeight="200"
                                        IsItemClickEnabled="False"
                                        ItemsSource="{Binding History}"
                                        SelectionMode="None">
                                        <ListView.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock
                                                    Padding="0,4,0,4"
                                                    FontSize="14"
                                                    Foreground="#444444"
                                                    Text="{Binding}" />
                                            </DataTemplate>
                                        </ListView.ItemTemplate>
                                    </ListView>
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </ScrollViewer>

        <!--  Mathematician of the day footer removed; now only shown in AppShell  -->

    </Grid>
</Page>
