<Page
    x:Class="InternetBankCalculator.Pages.LandingPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:InternetBankCalculator"
    Background="{ThemeResource BackgroundBrush}">

    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <StackPanel
            MaxWidth="780"
            Padding="24,60,24,60"
            HorizontalAlignment="Center"
            Spacing="40">

            <!--  Hero  -->
            <StackPanel HorizontalAlignment="Center" Spacing="16">
                <Image
                    MaxWidth="320"
                    HorizontalAlignment="Center"
                    Source="ms-appx:///Assets/doggerbank.png"
                    Stretch="Uniform" />
                <TextBlock
                    HorizontalAlignment="Center"
                    Foreground="{ThemeResource OnSurfaceBrush}"
                    Style="{ThemeResource HeadlineLarge}"
                    Text="Welcome to Doggerbank" />
                <TextBlock
                    MaxWidth="560"
                    HorizontalAlignment="Center"
                    Foreground="{ThemeResource OnSurfaceVariantBrush}"
                    Style="{ThemeResource BodyLarge}"
                    Text="A floating point bank at the edge of the North Sea — calculator, history, and the deep story of the land beneath the waves."
                    TextAlignment="Center"
                    TextWrapping="Wrap" />
            </StackPanel>

            <!--  Calculator card  -->
            <Border
                MaxWidth="340"
                Padding="32"
                HorizontalAlignment="Center"
                Background="{ThemeResource SurfaceBrush}"
                BorderBrush="{ThemeResource OutlineVariantBrush}"
                BorderThickness="1"
                CornerRadius="12">
                <Border.Shadow>
                    <ThemeShadow />
                </Border.Shadow>
                <StackPanel Spacing="12">
                    <Image
                        MaxWidth="48"
                        Margin="0,0,0,8"
                        HorizontalAlignment="Center"
                        Source="https://static.wikia.nocookie.net/computerscience/images/c/cf/Abacus.jpg/revision/latest?cb=20140901191838"
                        Stretch="Uniform" />
                    <TextBlock
                        HorizontalAlignment="Center"
                        Style="{ThemeResource TitleLarge}"
                        Text="Calculator" />
                    <TextBlock
                        Foreground="{ThemeResource OnSurfaceBrush}"
                        Style="{ThemeResource BodySmall}"
                        Text="Arithmetic, factorial, Fibonacci and prime number streaming — all powered by the Java Math API."
                        TextAlignment="Center"
                        TextWrapping="Wrap" />
                    <Button
                        x:Name="BtnToCalc"
                        Padding="20,10"
                        HorizontalAlignment="Center"
                        Background="{StaticResource LandingCtaBackground}"
                        Click="BtnToCalc_Click"
                        Content="Open Calculator"
                        CornerRadius="8"
                        FontSize="14"
                        FontWeight="SemiBold"
                        Foreground="White" />
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
