<Page x:Class="InternetBankCalculator.Pages.About.AboutPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F5F7FA">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="740"
                    HorizontalAlignment="Center"
                    Padding="24,60,24,60"
                    Spacing="32">
            <!-- Hero Header -->
            <StackPanel Spacing="12">
                <TextBlock Text="🏦 About"
                           FontSize="30"
                           FontWeight="Bold"
                           Foreground="#1A1A1A"/>
                <TextBlock Text="Dogger Bank is a fictitious internet bank — a case study demonstrating the latest and greatest in cloud-native technology, from a C# / WebAssembly frontend to a Java API running on Kubernetes in the cloud."
                           FontSize="15"
                           Foreground="#555555"
                           TextWrapping="Wrap"/>
            </StackPanel>
            <!-- Hero Image -->
            <Border CornerRadius="12">
                <Image Source="ms-appx:///Assets/about_hero.jpg"
                       Height="260"
                       Stretch="UniformToFill"
                       HorizontalAlignment="Stretch"/>
            </Border>
            <!-- Main Content Card -->
            <Border Background="White"
                    CornerRadius="12"
                    Padding="28"
                    BorderBrush="#E0E0E0"
                    BorderThickness="1">
                <StackPanel Spacing="8">
                    <TextBlock Text="Explore the case study topics:"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Margin="0,0,0,12"/>
                    <HyperlinkButton Content="Cloud Banking: Real-World Bank Cloud Migrations"
                                     Click="CloudBanking_Click"
                                     Margin="0,8,0,0"
                                     FontSize="16"
                                     Foreground="#0078D7"
                                     ToolTipService.ToolTip="Go to Cloud Banking: Real-World Bank Cloud Migrations page"/>
                    <HyperlinkButton Content="Mainframe Modernization"
                                     Click="MainframeModernization_Click"
                                     Margin="0,8,0,0"
                                     FontSize="16"
                                     Foreground="#0078D7"
                                     ToolTipService.ToolTip="Go to AS/400 &amp; COBOL Modernization page"/>
                    <HyperlinkButton Content="COBOL to Modern Languages"
                                     Click="CobolToModern_Click"
                                     Margin="0,8,0,0"
                                     FontSize="16"
                                     Foreground="#0078D7"
                                     ToolTipService.ToolTip="Go to COBOL to Java/C# quick guide page"/>
                    <HyperlinkButton Content="From Java to C#"
                                     Click="FromJavaToCSharp_Click"
                                     Margin="0,8,0,0"
                                     FontSize="16"
                                     Foreground="#0078D7"
                                     ToolTipService.ToolTip="Guide for Java developers transitioning to C#"/>
                    <StackPanel Margin="0,24,0,0">
                        <Border Height="1"
                                Background="#DDD"
                                Margin="0,16,0,16"/>
                        <TextBlock Text="Dogger Case Study"
                                   FontWeight="SemiBold"
                                   FontSize="14"
                                   Foreground="#888"
                                   Margin="0,0,0,8"/>
                        <HyperlinkButton Content="Dogger Bank"
                                         Click="DoggerBank_Click"
                                         Margin="0,0,0,0"
                                         FontSize="16"
                                         Foreground="#0078D7"
                                         ToolTipService.ToolTip="Go to Dogger Bank page"/>
                        <HyperlinkButton Content="Doggerland"
                                         Click="DoggerLand_Click"
                                         Margin="0,8,0,0"
                                         FontSize="16"
                                         Foreground="#0078D7"
                                         ToolTipService.ToolTip="Go to Doggerland page"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
