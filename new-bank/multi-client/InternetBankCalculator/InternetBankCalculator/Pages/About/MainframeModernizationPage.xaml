<Page
    x:Class="InternetBankCalculator.Pages.About.MainframeModernizationPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="#F5F7FA">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <StackPanel
            MaxWidth="740"
            Padding="24,60,24,60"
            HorizontalAlignment="Center"
            Spacing="32">
            <Border CornerRadius="12">
                <Image
                    Height="160"
                    HorizontalAlignment="Center"
                    Source="ms-appx:///Assets/AS400jpeg"
                    Stretch="Uniform" />
            </Border>
            <StackPanel Spacing="12">
                <TextBlock
                    Foreground="#1A1A1A"
                    Style="{ThemeResource HeadlineLarge}"
                    Text="Mainframe Modernization" />
                <TextBlock
                    Foreground="#555555"
                    Style="{ThemeResource BodyLarge}"
                    Text="AS400 IBM i in the Cloud and COBOL Modernization"
                    TextWrapping="Wrap" />
            </StackPanel>
            <Border
                Padding="28"
                Background="White"
                BorderBrush="#E0E0E0"
                BorderThickness="1"
                CornerRadius="12">
                <StackPanel>
                    <StackPanel Spacing="12">
                        <TextBlock Style="{ThemeResource TitleLarge}" Text="Cloud Providers for AS400 IBM i" />
                        <TextBlock TextWrapping="Wrap">IBM i and AS400 workloads can be hosted in the cloud using specialized offerings:</TextBlock>
                        <StackPanel Spacing="8">
                            <TextBlock Text="- IBM Cloud: IBM Power Systems Virtual Server runs IBM i, AIX, and Linux workloads natively." />
                            <TextBlock Text="- Microsoft Azure: Skytap on Azure allows running IBM i, AIX, and Power workloads in Azure with minimal changes." />
                            <TextBlock Text="- Google Cloud: Skytap via partner can also host IBM i workloads, but is less common than Azure or IBM Cloud." />
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Margin="0,24,0,0" Spacing="12">
                        <TextBlock Style="{ThemeResource TitleLarge}" Text="Modernizing COBOL and AS400 Systems" />
                        <TextBlock TextWrapping="Wrap">There are several strategies to modernize COBOL and AS400 workloads:</TextBlock>
                        <StackPanel Spacing="8">
                            <TextBlock Text="- Rehosting: Move existing workloads to cloud VMs or managed Power Systems IBM Cloud, Azure Skytap without code changes." />
                            <TextBlock Text="- Refactoring: Use automated tools to convert COBOL to modern languages Java, CSharp. Vendors: Micro Focus, Astadia, Heirloom Computing." />
                            <TextBlock Text="- API Enablement: Expose mainframe business logic as REST APIs using IBM zOS Connect or third party API gateways." />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
