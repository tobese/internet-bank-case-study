<Page x:Class="InternetBankCalculator.Pages.About.MainframeModernizationPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F5F7FA">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="740"
                    HorizontalAlignment="Center"
                    Padding="24,60,24,60"
                    Spacing="32">
            <Border CornerRadius="12">
                <Image Source="ms-appx:///Assets/AS400jpeg"
                       Height="160"
                       Stretch="Uniform"
                       HorizontalAlignment="Center"/>
            </Border>
            <StackPanel Spacing="12">
                <TextBlock Text="Mainframe Modernization"
                           FontSize="30"
                           FontWeight="Bold"
                           Foreground="#1A1A1A"/>
                <TextBlock Text="AS400 IBM i in the Cloud and COBOL Modernization"
                           FontSize="15"
                           Foreground="#555555"
                           TextWrapping="Wrap"/>
            </StackPanel>
            <Border Background="White"
                    CornerRadius="12"
                    Padding="28"
                    BorderBrush="#E0E0E0"
                    BorderThickness="1">
                <StackPanel>
                    <StackPanel Spacing="12">
                        <TextBlock Text="Cloud Providers for AS400 IBM i"
                                   FontSize="22"
                                   FontWeight="SemiBold"/>
                        <TextBlock TextWrapping="Wrap">IBM i and AS400 workloads can be hosted in the cloud using specialized offerings:</TextBlock>
                        <StackPanel Spacing="8">
                            <TextBlock Text="- IBM Cloud: IBM Power Systems Virtual Server runs IBM i, AIX, and Linux workloads natively."/>
                            <TextBlock Text="- Microsoft Azure: Skytap on Azure allows running IBM i, AIX, and Power workloads in Azure with minimal changes."/>
                            <TextBlock Text="- Google Cloud: Skytap via partner can also host IBM i workloads, but is less common than Azure or IBM Cloud."/>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Spacing="12"
                                Margin="0,24,0,0">
                        <TextBlock Text="Modernizing COBOL and AS400 Systems"
                                   FontSize="22"
                                   FontWeight="SemiBold"/>
                        <TextBlock TextWrapping="Wrap">There are several strategies to modernize COBOL and AS400 workloads:</TextBlock>
                        <StackPanel Spacing="8">
                            <TextBlock Text="- Rehosting: Move existing workloads to cloud VMs or managed Power Systems IBM Cloud, Azure Skytap without code changes."/>
                            <TextBlock Text="- Refactoring: Use automated tools to convert COBOL to modern languages Java, CSharp. Vendors: Micro Focus, Astadia, Heirloom Computing."/>
                            <TextBlock Text="- API Enablement: Expose mainframe business logic as REST APIs using IBM zOS Connect or third party API gateways."/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
