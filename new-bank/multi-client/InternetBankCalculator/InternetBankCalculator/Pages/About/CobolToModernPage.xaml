<Page
    x:Class="InternetBankCalculator.Pages.About.CobolToModernPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:InternetBankCalculator"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer
        Padding="24,60,24,60"
        HorizontalAlignment="Center"
        HorizontalScrollBarVisibility="Disabled"
        VerticalScrollBarVisibility="Auto">
        <StackPanel
            MaxWidth="740"
            HorizontalAlignment="Center"
            Spacing="20">
            <TextBlock
                Foreground="{ThemeResource OnSurfaceBrush}"
                Style="{ThemeResource HeadlineLarge}"
                Text="💾➡️☕/💻 COBOL to Modern Languages" />
            <TextBlock
                Foreground="{ThemeResource OnSurfaceVariantBrush}"
                Style="{ThemeResource BodyLarge}"
                Text="A quick guide for COBOL programmers transitioning to modern object-oriented languages: Java and C#."
                TextWrapping="Wrap" />
            <Border CornerRadius="12">
                <Image
                    Height="180"
                    HorizontalAlignment="Stretch"
                    Source="ms-appx:///Assets/doggerbank.png"
                    Stretch="UniformToFill" />
            </Border>
            <Border
                Padding="28"
                Background="{ThemeResource SurfaceBrush}"
                BorderBrush="{ThemeResource OutlineVariantBrush}"
                BorderThickness="1"
                CornerRadius="12">
                <StackPanel Spacing="12">
                    <TextBlock Style="{ThemeResource TitleLarge}" Text="COBOL to Modern: Key Concepts" />
                    <TextBlock Text="• Procedural (COBOL) vs Object-Oriented (Java/C#)" TextWrapping="Wrap" />
                    <TextBlock Text="• Data Division (COBOL) → Classes/Fields (Java/C#)" TextWrapping="Wrap" />
                    <TextBlock Text="• PERFORM (COBOL) → for/while loops (Java/C#)" TextWrapping="Wrap" />
                    <TextBlock Text="• MOVE/ADD/COMPUTE → =, +, -, *, / operators" TextWrapping="Wrap" />
                    <TextBlock Text="• IF/ELSE, EVALUATE → if/else, switch" TextWrapping="Wrap" />
                    <TextBlock Text="• File I/O → Streams, File APIs" TextWrapping="Wrap" />
                    <TextBlock Text="• Error handling: GOTO/STOP RUN → try/catch/finally" TextWrapping="Wrap" />
                    <TextBlock Text="• Batch jobs → Scheduled tasks, async methods" TextWrapping="Wrap" />
                    <TextBlock Text="• Mainframe DB (VSAM, IMS) → Relational DB (JPA, Entity Framework)" TextWrapping="Wrap" />
                </StackPanel>
            </Border>
            <TextBlock
                Margin="0,16,0,0"
                Foreground="#888"
                Style="{ThemeResource BodySmall}"
                Text="See documentation or onboarding guides for more details and code examples." />
        </StackPanel>
    </ScrollViewer>
</Page>
