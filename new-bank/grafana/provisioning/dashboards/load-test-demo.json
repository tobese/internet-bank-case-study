{
  "uid": "internet-bank-demo",
  "title": "Internet Bank — Live Load Test",
  "tags": ["internet-bank", "k6", "demo"],
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Active VUs",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 50, "color": "yellow" },
              { "value": 100, "color": "red" }
            ]
          },
          "unit": "short"
        }
      },
      "targets": [
        {
          "expr": "k6_vus",
          "legendFormat": "VUs"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Requests / sec",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "blue" },
              { "value": 100, "color": "green" }
            ]
          },
          "unit": "reqps",
          "decimals": 1
        }
      },
      "targets": [
        {
          "expr": "rate(k6_http_reqs_total[30s])",
          "legendFormat": "req/s"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Error Rate",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 1, "color": "yellow" },
              { "value": 5, "color": "red" }
            ]
          },
          "unit": "percent",
          "decimals": 2
        }
      },
      "targets": [
        {
          "expr": "rate(k6_http_req_failed_total[30s]) / rate(k6_http_reqs_total[30s]) * 100",
          "legendFormat": "error %"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "p95 Latency",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 500, "color": "yellow" },
              { "value": 2000, "color": "red" }
            ]
          },
          "unit": "ms",
          "decimals": 0
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(k6_http_req_duration_milliseconds_bucket[1m])) by (le))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "id": 5,
      "type": "row",
      "title": "🔥 Load",
      "gridPos": { "x": 0, "y": 4, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "VUs & Throughput",
      "gridPos": { "x": 0, "y": 5, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2 } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "req/s" },
            "properties": [
              { "id": "custom.axisPlacement", "value": "right" },
              { "id": "unit", "value": "reqps" },
              {
                "id": "color",
                "value": { "mode": "fixed", "fixedColor": "orange" }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Virtual Users" },
            "properties": [
              {
                "id": "color",
                "value": { "mode": "fixed", "fixedColor": "#5794F2" }
              },
              { "id": "custom.fillOpacity", "value": 20 }
            ]
          }
        ]
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "k6_vus",
          "legendFormat": "Virtual Users"
        },
        {
          "expr": "rate(k6_http_reqs_total[30s])",
          "legendFormat": "req/s"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Latency Percentiles",
      "gridPos": { "x": 12, "y": 5, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "lineWidth": 2 }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "p99" },
            "properties": [
              {
                "id": "color",
                "value": { "mode": "fixed", "fixedColor": "red" }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "p95" },
            "properties": [
              {
                "id": "color",
                "value": { "mode": "fixed", "fixedColor": "orange" }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "p50" },
            "properties": [
              {
                "id": "color",
                "value": { "mode": "fixed", "fixedColor": "green" }
              }
            ]
          }
        ]
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(k6_http_req_duration_milliseconds_bucket[1m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(k6_http_req_duration_milliseconds_bucket[1m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(k6_http_req_duration_milliseconds_bucket[1m])) by (le))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "HTTP Error Rate",
      "gridPos": { "x": 0, "y": 13, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": { "lineWidth": 2, "fillOpacity": 15 },
          "color": { "mode": "fixed", "fixedColor": "red" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "value": null, "color": "green" },
              { "value": 1, "color": "red" }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "rate(k6_http_req_failed_total[30s]) / rate(k6_http_reqs_total[30s]) * 100",
          "legendFormat": "error %"
        }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Checks Pass Rate",
      "gridPos": { "x": 12, "y": 13, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": { "lineWidth": 2 },
          "min": 0,
          "max": 1
        }
      },
      "targets": [
        {
          "expr": "rate(k6_checks_total{result=\"pass\"}[30s]) / rate(k6_checks_total[30s])",
          "legendFormat": "pass rate"
        }
      ]
    },
    {
      "id": 10,
      "type": "row",
      "title": "⚙️ API — Spring Boot",
      "gridPos": { "x": 0, "y": 21, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "API Request Rate (Spring Boot)",
      "gridPos": { "x": 0, "y": 22, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "lineWidth": 2 } }
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{uri=~\"/api/.*\"}[1m])) by (uri, status)",
          "legendFormat": "{{uri}} {{status}}"
        }
      ]
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "JVM Heap Memory",
      "gridPos": { "x": 12, "y": 22, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "bytes", "custom": { "lineWidth": 2 } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "used" },
            "properties": [
              {
                "id": "color",
                "value": { "mode": "fixed", "fixedColor": "#5794F2" }
              },
              { "id": "custom.fillOpacity", "value": 20 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "committed" },
            "properties": [
              {
                "id": "color",
                "value": { "mode": "fixed", "fixedColor": "gray" }
              },
              {
                "id": "custom.lineStyle",
                "value": { "dash": [4, 4], "fill": "dash" }
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "expr": "sum(jvm_memory_used_bytes{area=\"heap\"})",
          "legendFormat": "used"
        },
        {
          "expr": "sum(jvm_memory_committed_bytes{area=\"heap\"})",
          "legendFormat": "committed"
        }
      ]
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "HikariCP Connection Pool",
      "gridPos": { "x": 0, "y": 30, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2 } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "active" },
            "properties": [
              {
                "id": "color",
                "value": { "mode": "fixed", "fixedColor": "orange" }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "pending" },
            "properties": [
              {
                "id": "color",
                "value": { "mode": "fixed", "fixedColor": "red" }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "idle" },
            "properties": [
              {
                "id": "color",
                "value": { "mode": "fixed", "fixedColor": "green" }
              }
            ]
          }
        ]
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "hikaricp_connections_active",
          "legendFormat": "active"
        },
        {
          "expr": "hikaricp_connections_idle",
          "legendFormat": "idle"
        },
        {
          "expr": "hikaricp_connections_pending",
          "legendFormat": "pending"
        }
      ]
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "API p95 Latency (Spring Boot)",
      "gridPos": { "x": 12, "y": 30, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "lineWidth": 2 } }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{uri=~\"/api/.*\"}[1m])) by (le, uri))",
          "legendFormat": "p95 {{uri}}"
        }
      ]
    },
    {
      "id": 15,
      "type": "row",
      "title": "🐘 PostgreSQL",
      "gridPos": { "x": 0, "y": 38, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 16,
      "type": "timeseries",
      "title": "DB Active Connections",
      "gridPos": { "x": 0, "y": 39, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 15 }
        }
      },
      "targets": [
        {
          "expr": "pg_stat_activity_count{state=\"active\"}",
          "legendFormat": "active"
        },
        {
          "expr": "pg_stat_activity_count{state=\"idle\"}",
          "legendFormat": "idle"
        }
      ]
    },
    {
      "id": 17,
      "type": "timeseries",
      "title": "DB Transaction Rate",
      "gridPos": { "x": 12, "y": 39, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "lineWidth": 2 } }
      },
      "targets": [
        {
          "expr": "rate(pg_stat_database_xact_commit_total{datname=\"internet_bank\"}[1m])",
          "legendFormat": "commits/s"
        },
        {
          "expr": "rate(pg_stat_database_xact_rollback_total{datname=\"internet_bank\"}[1m])",
          "legendFormat": "rollbacks/s"
        }
      ]
    },
    {
      "id": 18,
      "type": "row",
      "title": "⚡ Redis Cache",
      "gridPos": { "x": 0, "y": 47, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 19,
      "type": "timeseries",
      "title": "Cache Hit Rate",
      "gridPos": { "x": 0, "y": 48, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": { "lineWidth": 2, "fillOpacity": 20 },
          "color": { "mode": "fixed", "fixedColor": "green" }
        }
      },
      "targets": [
        {
          "expr": "rate(redis_keyspace_hits_total[1m]) / (rate(redis_keyspace_hits_total[1m]) + rate(redis_keyspace_misses_total[1m]))",
          "legendFormat": "hit rate"
        }
      ]
    },
    {
      "id": 20,
      "type": "timeseries",
      "title": "Redis Commands / sec",
      "gridPos": { "x": 12, "y": 48, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "lineWidth": 2 } }
      },
      "targets": [
        {
          "expr": "rate(redis_commands_processed_total[1m])",
          "legendFormat": "ops/s"
        },
        {
          "expr": "redis_connected_clients",
          "legendFormat": "clients"
        }
      ]
    },
    {
      "id": 21,
      "type": "row",
      "title": "☸️ Kubernetes (k8s) / 🖥️ JVM (local)",
      "gridPos": { "x": 0, "y": 56, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 22,
      "type": "timeseries",
      "title": "API Pod Count (HPA scaling) — k8s only",
      "gridPos": { "x": 0, "y": 57, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 20 },
          "decimals": 0
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "desired" },
            "properties": [
              {
                "id": "color",
                "value": { "mode": "fixed", "fixedColor": "orange" }
              },
              {
                "id": "custom.lineStyle",
                "value": { "dash": [6, 3], "fill": "dash" }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "ready" },
            "properties": [
              {
                "id": "color",
                "value": { "mode": "fixed", "fixedColor": "#5794F2" }
              }
            ]
          }
        ]
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "kube_deployment_status_replicas_ready{deployment=\"api\",namespace=\"internet-bank\"}",
          "legendFormat": "ready"
        },
        {
          "expr": "kube_horizontalpodautoscaler_status_desired_replicas{horizontalpodautoscaler=\"api-hpa\",namespace=\"internet-bank\"}",
          "legendFormat": "desired"
        }
      ]
    },
    {
      "id": 23,
      "type": "timeseries",
      "title": "Web-Client Pod Count — k8s only",
      "gridPos": { "x": 12, "y": 57, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 20 },
          "decimals": 0,
          "color": { "mode": "fixed", "fixedColor": "purple" }
        }
      },
      "targets": [
        {
          "expr": "kube_deployment_status_replicas_ready{deployment=\"web-client\",namespace=\"internet-bank\"}",
          "legendFormat": "ready"
        },
        {
          "expr": "kube_horizontalpodautoscaler_status_desired_replicas{horizontalpodautoscaler=\"web-client-hpa\",namespace=\"internet-bank\"}",
          "legendFormat": "desired"
        }
      ]
    },
    {
      "id": 24,
      "type": "timeseries",
      "title": "JVM CPU Usage",
      "gridPos": { "x": 0, "y": 66, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "process" },
            "properties": [
              {
                "id": "color",
                "value": { "mode": "fixed", "fixedColor": "#5794F2" }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "system" },
            "properties": [
              {
                "id": "color",
                "value": { "mode": "fixed", "fixedColor": "orange" }
              }
            ]
          }
        ]
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "process_cpu_usage{job=\"spring-boot-api\"}",
          "legendFormat": "process"
        },
        {
          "expr": "system_cpu_usage{job=\"spring-boot-api\"}",
          "legendFormat": "system"
        }
      ]
    },
    {
      "id": 25,
      "type": "timeseries",
      "title": "JVM Threads",
      "gridPos": { "x": 12, "y": 66, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "decimals": 0
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "live" },
            "properties": [
              {
                "id": "color",
                "value": { "mode": "fixed", "fixedColor": "#5794F2" }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "peak" },
            "properties": [
              {
                "id": "color",
                "value": { "mode": "fixed", "fixedColor": "orange" }
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "daemon" },
            "properties": [
              {
                "id": "color",
                "value": { "mode": "fixed", "fixedColor": "green" }
              }
            ]
          }
        ]
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "jvm_threads_live_threads{job=\"spring-boot-api\"}",
          "legendFormat": "live"
        },
        {
          "expr": "jvm_threads_peak_threads{job=\"spring-boot-api\"}",
          "legendFormat": "peak"
        },
        {
          "expr": "jvm_threads_daemon_threads{job=\"spring-boot-api\"}",
          "legendFormat": "daemon"
        }
      ]
    }
  ],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0,
        "label": "Datasource"
      }
    ]
  },
  "annotations": {
    "list": [
      {
        "name": "k6 stages",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "enable": true,
        "hide": false,
        "iconColor": "rgba(255,96,96,0.7)",
        "expr": "changes(k6_vus[30s]) != 0",
        "step": "60s",
        "titleFormat": "VU change",
        "tagKeys": "",
        "textFormat": ""
      }
    ]
  }
}
